        ctk.CTkOptionMenu(qr, variable=self.fps_var, width=110,
                          values=["Match GIF", "60", "30", "24", "15"],
                          fg_color=G2M_ACCENT, button_color=G2M_HOVER,
                          button_hover_color="#157ab5").pack(side="left", padx=8)

        # Save folder
        sr = ctk.CTkFrame(self, fg_color="transparent"); sr.pack(fill="x", padx=18, pady=(8,4))
        ctk.CTkLabel(sr, text="Save to:").pack(side="left")
