        # Progress + log
        self.progress_bar = ctk.CTkProgressBar(self, width=640, progress_color=DC_ACCENT)
        self.progress_bar.set(0); self.progress_bar.pack()
        self.status_lbl = ctk.CTkLabel(self, text="Ready.", text_color="gray60", wraplength=640)
        self.status_lbl.pack(pady=4)
        self.log_box = ctk.CTkTextbox(
            self, width=640, state="disabled",
            font=ctk.CTkFont(family="Courier", size=10))
        self.log_box.pack(padx=18, pady=(0,10), fill="both", expand=True)

    # ── filename helpers ────────────────────────────────────────────────────
    def _toggle_filename(self):
        active = self._custom_name_var.get()
        self._filename_entry.configure(
            state="normal"  if active else "disabled",
            text_color="white" if active else "gray50")
        self._fn_clear_btn.configure(state="normal" if active else "disabled")
        if active:
            self._filename_entry.focus_set()
        else:
            hint = getattr(self, "_last_filename_hint", "")
            if hint and not self._filename_entry.get().strip():
                self._filename_entry.configure(state="normal")
                self._filename_entry.delete(0, "end")
                self._filename_entry.insert(0, hint)
                self._filename_entry.configure(state="disabled", text_color="gray50")

    def _clear_filename(self):
        self._filename_entry.delete(0, "end")
        self._filename_entry.focus_set()

    # ── fetch (HEAD request to detect type + size) ──────────────────────────
    def _fetch(self):
        url = self.url_entry.get().strip()
        if not url:
            self.info_lbl.configure(text="⚠  Paste a Discord CDN or Tenor link first.", text_color="#ff6b6b")
            return
        self.fetch_btn.configure(state="disabled", text="Loading…")
        self.dl_btn.configure(state="disabled")
        self.info_lbl.configure(text="Fetching info…", text_color="#a8d8f8")
        self._detected = None
        self._resolved_url = None
        threading.Thread(target=self._fetch_worker, args=(url,), daemon=True).start()

    @staticmethod
    def _resolve_url(url):
        """Return (direct_url, suggested_filename) resolving Tenor pages if needed."""
        import urllib.request, urllib.parse, json, re
        if "tenor.com/view/" in url or "tenor.com/en-US/view/" in url:
            # Extract numeric ID from the end of the URL
            m = re.search(r"-(\d+)/?$", url)
            if not m:
                raise ValueError("Could not parse Tenor GIF ID from URL")
            gif_id = m.group(1)
            # Tenor API v2 — requires your own key from tenor.com/developer
            tenor_key = get_pref("tenor_api_key", "").strip()
            if not tenor_key:
                raise ValueError(
                    "No Tenor API key set.\n\n"
                    "Get a free key at tenor.com/developer, then add it in\n"
                    "Settings → Behaviour → Tenor API Key."
                )
            api_url = (
                f"https://tenor.googleapis.com/v2/posts"
                f"?ids={gif_id}&key={tenor_key}&limit=1"
                f"&media_filter=gif,mp4"
            )
            req = urllib.request.Request(api_url, headers={"User-Agent": "Mozilla/5.0"})
            with urllib.request.urlopen(req, timeout=15) as resp:
                data = json.loads(resp.read().decode("utf-8"))
            results = data.get("results", [])
            if not results:
                raise ValueError("Tenor API returned no results for this GIF")
            media = results[0].get("media_formats", {})
            direct = None
            ext = "gif"
            for fmt in ("gif", "mediumgif", "tinygif", "mp4", "webm"):
                entry = media.get(fmt)
                if entry and entry.get("url"):
                    direct = entry["url"]
                    ext = "gif" if "gif" in fmt else fmt
                    break
            if not direct:
                raise ValueError("No downloadable media found in Tenor response")
            slug = re.sub(r"-\d+/?$", "", url.rstrip("/").split("/")[-1])
            return direct, f"{slug}.{ext}"
        return url, urllib.parse.urlparse(url).path.split("/")[-1].split("?")[0]

    def _fetch_worker(self, url):
        import urllib.request, urllib.parse
        try:
            direct_url, suggested_fname = self._resolve_url(url)

            req = urllib.request.Request(direct_url, method="HEAD",
                                         headers={"User-Agent": "Mozilla/5.0"})
            with urllib.request.urlopen(req, timeout=15) as resp:
                mime     = resp.headers.get("Content-Type", "").split(";")[0].strip().lower()
                raw_size = resp.headers.get("Content-Length", "")
                size_str = self._fmt_size(int(raw_size)) if raw_size.isdigit() else "unknown size"

            fname = suggested_fname
            ext   = fname.rsplit(".", 1)[-1].lower() if "." in fname else ""

            # Determine category
            category = self._TYPE_MAP.get(mime, "other")
            if category == "other":
                if ext in ("gif", "apng"):                          category = "gif"
                elif ext in ("png","jpg","jpeg","webp","bmp","tiff"): category = "image"
                elif ext in ("mp4","webm","mov","mkv"):             category = "video"
                elif ext in ("ogg","oga","opus","mp3","wav","flac","aac","m4a"): category = "audio"

            # Store resolved URL so _dl_worker uses the direct link
            self._resolved_url = direct_url
            self._detected = (category, ext, size_str, fname, mime)
            icon  = self._ICONS.get(category, "📄")
            label = category.upper() if category != "other" else "FILE"
            self.after(0, lambda: self.info_lbl.configure(
                text=f"{icon}  {label}  ·  {fname}  ·  {size_str}  ·  ✅ Ready to download",
                text_color="#a8d8f8"))
            self.after(0, lambda n=fname.rsplit(".",1)[0]: self._set_filename_hint(n))
            self.after(0, lambda: self.dl_btn.configure(state="normal"))
        except Exception as e:
            self.after(0, lambda: self.info_lbl.configure(
                text=f"⚠  {e}", text_color="#ff6b6b"))
            self.after(0, lambda: self.dl_btn.configure(state="disabled"))
        finally:
            self.after(0, lambda: self.fetch_btn.configure(state="normal", text="Load Info"))

    @staticmethod
    def _fmt_size(n):
        for unit in ("B","KB","MB","GB"):
            if n < 1024:
                return f"{n:.1f} {unit}"
            n /= 1024
        return f"{n:.1f} TB"

    # ── download ────────────────────────────────────────────────────────────
    def _start(self):
        if not self._confirm_download("Download"):
            return
        url  = self.url_entry.get().strip()
        save = self.save_var.get().strip()
        if not url:
            self._set_status("⚠  No URL entered."); return
        if not save:
            self._set_status("⚠  No save folder selected."); return
        self._maybe_clear_log()
        set_pref("save_folder_discord", save)
        push_folder_history("save_folder_discord", save)
        self.dl_btn.configure(state="disabled", text="Downloading…")
        self._set_status("Downloading…"); self._set_progress(0)
        threading.Thread(target=self._dl_worker, args=(url, save), daemon=True).start()

    def _dl_worker(self, url, save):
        import urllib.request, urllib.parse
        try:
            # Use pre-resolved direct URL if available (e.g. Tenor)
            direct_url = getattr(self, "_resolved_url", None) or url
            # Resolve filename
            custom = self._filename_entry.get().strip() if self._custom_name_var.get() else ""
            if self._detected:
                orig = self._detected[3]   # fname stored during fetch
            else:
                path = urllib.parse.urlparse(direct_url).path
                orig = path.split("/")[-1].split("?")[0]
            ext   = orig.rsplit(".", 1)[-1] if "." in orig else "bin"
            fname = f"{custom}.{ext}" if custom else orig
            if not fname:
                fname = "discord_file." + ext

            dest = Path(save) / fname
            Path(save).mkdir(parents=True, exist_ok=True)

            self.after(0, lambda: self._log(f"💾  Downloading → {dest.name}"))

            req = urllib.request.Request(direct_url, headers={"User-Agent": "Mozilla/5.0"})
            with urllib.request.urlopen(req, timeout=60) as resp:
                total = int(resp.headers.get("Content-Length") or 0)
                done  = 0
                chunk = 65536
                with open(dest, "wb") as f:
                    while True:
                        buf = resp.read(chunk)
                        if not buf:
                            break
                        f.write(buf)
                        done += len(buf)
                        if total:
                            self.after(0, lambda p=done/total: self._set_progress(p))

            self.after(0, lambda: self._set_progress(1.0))
            self.after(0, lambda: self._log(f"✅  Saved: {dest}"))
            self.after(0, lambda: self._set_status(f"✅  Done — {dest.name}"))
            self._last_file = str(dest)
            self.after(0, lambda: _notify_done(str(dest.parent), self._open_folder, str(dest)))
        except Exception as e:
            self.after(0, lambda: self._log(f"❌  Error: {e}"))
            self.after(0, lambda: self._set_status(f"❌  {e}"))
        finally:
            self.after(0, lambda: self.dl_btn.configure(state="normal", text="💾  Download"))


    def _open_folder(self, path):
        _open_and_highlight(path)

