                self._filename_entry.configure(state="normal")
                self._filename_entry.delete(0, "end")
                self._filename_entry.insert(0, hint)
                self._filename_entry.configure(state="disabled", text_color="gray50")

    def _clear_filename(self):
        self._filename_entry.delete(0, "end")
        self._filename_entry.focus_set()

    def _get_outtmpl(self, save):
        custom = self._filename_entry.get().strip() if self._custom_name_var.get() else ""
        if custom:
            return str(Path(save) / f"{custom}.%(ext)s")
        return str(Path(save) / "%(title)s.%(ext)s")

    # ── Fetch info ────────────────────────────────────────────────────────────
    def _fetch(self):
        url = self.url_entry.get().strip()
        if not url:
            return
        if "spotify.com" not in url:
            self.info_lbl.configure(
                text="⚠  Doesn't look like a Spotify URL.", text_color="#ff6b6b")
            return
        self.fetch_btn.configure(state="disabled", text="Loading…")
        self.dl_btn.configure(state="disabled")
        self.info_lbl.configure(text="Fetching info from Spotify…", text_color="gray55")
        threading.Thread(target=self._do_fetch, args=(url,), daemon=True).start()

    def _do_fetch(self, url):
        """Fetch track metadata via Spotify's free oEmbed + open API — no auth needed."""
        try:
            import urllib.parse as _up, urllib.request as _ur, json as _json

            url_clean = url.split("?")[0].rstrip("/")
            parts = [p for p in _up.urlparse(url_clean).path.split("/") if p]

            TYPE_ICONS = {
                "track":    "🎵  Track",
                "album":    "💿  Album",
                "playlist": "📋  Playlist",
                "artist":   "🎤  Artist",
            }

            if not (len(parts) >= 2 and parts[0] in TYPE_ICONS):
                info   = "⚠  Unrecognised Spotify URL — expected /track/, /album/, /playlist/ or /artist/"
                colour = "#ff6b6b"
                self.after(0, lambda i=info, c=colour: (
                    self.info_lbl.configure(text=i, text_color=c),
                    self.fetch_btn.configure(state="normal", text="Load Info")
                ))
                return

            kind  = parts[0]
            icon  = TYPE_ICONS[kind]
            sp_id = parts[1]

            # Reset stored metadata
            self._fetched_title  = ""
            self._fetched_meta   = {}

            # oEmbed gives us the display title
            title = ""
            try:
                oembed_url = f"https://open.spotify.com/oembed?url={_up.quote(url_clean)}"
                req = _ur.Request(oembed_url, headers={"User-Agent": "Mozilla/5.0"})
                with _ur.urlopen(req, timeout=6) as resp:
                    data  = _json.loads(resp.read().decode())
                    title = data.get("title", "").strip()
                    thumbnail_url = data.get("thumbnail_url", "")
            except Exception:
                title = ""
                thumbnail_url = ""

            # For tracks, also hit the open embed page for artist/album info
            artist = ""
            album  = ""
            if kind == "track":
                try:
                    track_url = f"https://open.spotify.com/track/{sp_id}"
                    req2 = _ur.Request(track_url, headers={"User-Agent": "Mozilla/5.0"})
                    with _ur.urlopen(req2, timeout=6) as resp2:
                        html = resp2.read().decode("utf-8", errors="ignore")
                    # Extract from og meta tags
                    import re as _re
                    m_desc = _re.search(r'<meta[^>]+property="og:description"[^>]+content="([^"]+)"', html)
                    if m_desc:
                        desc = m_desc.group(1)
                        # Format is usually "Song · Artist · Album"
                        desc_parts = [p.strip() for p in desc.split("·")]
                        if len(desc_parts) >= 2:
                            artist = desc_parts[1]
                        if len(desc_parts) >= 3:
                            album = desc_parts[2]
                except Exception:
                    pass

            self._fetched_title = title
            self._fetched_meta  = {
                "title":         title,
                "artist":        artist,
                "album":         album,
                "thumbnail_url": thumbnail_url,
            }

            if title:
                extra = f"  ·  {artist}" if artist else ""
                info   = f"{icon}  ·  {title}{extra}  ·  ✅ Ready to download"
                colour = "#4fc3f7"
            else:
                info   = f"{icon}  ·  {sp_id[:22]}  ·  ✅ Ready to download"
                colour = "#4fc3f7"

            def _update_ui(i=info, c=colour, t=title):
                self.info_lbl.configure(text=i, text_color=c)
                self.fetch_btn.configure(state="normal", text="Load Info")
                self.dl_btn.configure(state="normal")
                if t:
                    self._set_filename_hint(t)
            self.after(0, _update_ui)

        except Exception as e:
            err = str(e)[:120]
            self.after(0, lambda e=err: (
                self.info_lbl.configure(text=f"⚠  {e}", text_color="#ff6b6b"),
                self.fetch_btn.configure(state="normal", text="Load Info"),
                self.dl_btn.configure(state="disabled")
            ))

    # ── Download ──────────────────────────────────────────────────────────────
    def _start(self):
        url  = self.url_entry.get().strip()
        save = self.save_var.get().strip()
        if not url:  messagebox.showwarning("No URL","Paste a Spotify URL first."); return
        if "spotify.com" not in url:
            messagebox.showwarning("Bad URL","Doesn't look like a Spotify URL."); return
        if not save: messagebox.showwarning("No folder","Choose a save folder."); return
        os.makedirs(save, exist_ok=True)
        if not self._confirm_download("Spotify download"): return
        self._maybe_clear_log()
        self._sp_proc = None
        self.dl_btn.configure(state="disabled", text="Downloading…")
        self._cancel_btn.pack(side="left", padx=(10,0))
        self._set_progress(0); self._log(f"▶  {url}")
        threading.Thread(target=self._worker, args=(url, save), daemon=True).start()

    def _worker(self, url, save):
        """
        Download via yt-dlp searching YouTube Music directly.
        Bypasses Spotify's rate-limited API entirely — uses the track title
        from the oEmbed fetch to search ytmusic:, falling back to spotdl
        for playlists/albums where we need multiple track names.
        """
        import yt_dlp
        env = os.environ.copy()
        env["PATH"] = str(FFMPEG_DIR) + os.pathsep + env.get("PATH", "")

        import urllib.parse as _up
        url_clean = url.split("?")[0].rstrip("/")
        parts = [p for p in _up.urlparse(url_clean).path.split("/") if p]
        kind  = parts[0] if parts else ""

        if kind == "track" and getattr(self, "_fetched_title", ""):
            # Single track — search YouTube Music directly, no Spotify API needed
            title    = self._fetched_title
            meta     = getattr(self, "_fetched_meta", {})
            custom   = self._filename_entry.get().strip() if self._custom_name_var.get() else ""
            out_name = custom if custom else re.sub(r'[\\/:*?"<>|]', "_", title)
            outtmpl  = str(Path(save) / f"{out_name}.%(ext)s")

            opts = {
                "format":          "bestaudio/best",
                "outtmpl":         outtmpl,
                "ffmpeg_location": str(_ffmpeg_path),
                "quiet":           True,
                "no_warnings":     True,
                "postprocessors":  [{
                    "key":              "FFmpegExtractAudio",
                    "preferredcodec":   "mp3",
                    "preferredquality": self.bitrate_var.get().replace("k", ""),
                }],
                "progress_hooks":  [self._progress_hook],
            }
            try:
                self.after(0, self._set_status, f"🔍  Searching YouTube Music for: {title[:60]}…")
                search_query = f"ytsearch1:{title}"
                with yt_dlp.YoutubeDL(opts) as ydl:
                    ydl.download([search_query])

                # Embed Spotify metadata via mutagen
                mp3_path = Path(save) / f"{out_name}.mp3"
                if mp3_path.exists() and meta:
                    self.after(0, self._set_status, "🏷  Embedding metadata…")
                    self._embed_metadata(mp3_path, meta)

                self._last_file = str(mp3_path) if mp3_path.exists() else None
                self.after(0, self._done, save)
            except Exception as exc:
                self.after(0, self._err, str(exc))
        else:
            # Playlist / album / artist — fall back to spotdl
            # --threads 1 serialises downloads to avoid hammering the Spotify API
            # --no-cache prevents stale token issues that can trigger false 429s
            cmd = [
                sys.executable, "-m", "spotdl", url,
                "--output",       save,
                "--bitrate",      self.bitrate_var.get(),
                "--format",       "mp3",
                "--audio",        "youtube-music",
                "--headless",
                "--threads",      "1",
                "--no-cache",
                "--max-retries",  "5",
                "--print-errors",
            ]
            try:
                proc = subprocess.Popen(cmd, stdout=subprocess.PIPE, stderr=subprocess.STDOUT,
                                        text=True, bufsize=1, env=env)
                self._sp_proc = proc
                total = done = 0
                _rate_limit_sleep = 0
                for line in proc.stdout:
                    line = line.rstrip()
                    if not line: continue
                    self.after(0, self._log, line)
                    ll = line.lower()
                    if "rate" in ll and "limit" in ll:
                        _rate_limit_sleep = min(_rate_limit_sleep + 5, 30)
                        msg = f"⏳  Rate limited — waiting {_rate_limit_sleep}s before retrying…"
                        self.after(0, self._set_status, msg)
                        import time; time.sleep(_rate_limit_sleep)
                    elif "429" in line:
                        _rate_limit_sleep = min(_rate_limit_sleep + 10, 60)
                        msg = f"⏳  HTTP 429 — waiting {_rate_limit_sleep}s…"
                        self.after(0, self._set_status, msg)
                        import time; time.sleep(_rate_limit_sleep)
                    else:
                        _rate_limit_sleep = max(_rate_limit_sleep - 1, 0)
                    m = re.search(r"Downloaded\s+(\d+)/(\d+)", line)
                    if m:
                        done, total = int(m.group(1)), int(m.group(2))
                        self.after(0, self._set_progress, done/total if total else 0)
                        self.after(0, self._set_status, f"📥  {done}/{total} tracks…")
                proc.wait()
                any_mp3 = any(Path(save).rglob("*.mp3"))
                if proc.returncode == 0 or any_mp3:
                    self.after(0, self._done, save)
                else:
                    self.after(0, self._err, "spotdl exited with errors — check the log.")
            except Exception as exc:
                self.after(0, self._err, str(exc))

    def _embed_metadata(self, mp3_path: Path, meta: dict):
        """Embed ID3 tags and album art into the downloaded MP3 using mutagen."""
        try:
            _pip_install("mutagen", "mutagen")
            from mutagen.id3 import ID3, TIT2, TPE1, TALB, APIC, ID3NoHeaderError
            import urllib.request as _ur

            try:
                tags = ID3(str(mp3_path))
            except ID3NoHeaderError:
                tags = ID3()

            if meta.get("title"):
                tags["TIT2"] = TIT2(encoding=3, text=meta["title"])
            if meta.get("artist"):
                tags["TPE1"] = TPE1(encoding=3, text=meta["artist"])
            if meta.get("album"):
                tags["TALB"] = TALB(encoding=3, text=meta["album"])

            # Embed album art from Spotify thumbnail
            thumb_url = meta.get("thumbnail_url", "")
            if thumb_url:
                try:
                    req = _ur.Request(thumb_url, headers={"User-Agent": "Mozilla/5.0"})
                    with _ur.urlopen(req, timeout=8) as resp:
                        img_data = resp.read()
                    tags["APIC"] = APIC(
                        encoding=3, mime="image/jpeg",
                        type=3, desc="Cover", data=img_data,
                    )
                except Exception:
                    pass

            tags.save(str(mp3_path), v2_version=3)
            self.after(0, self._log, f"🏷  Metadata embedded: {mp3_path.name}")
        except Exception as e:
            self.after(0, self._log, f"⚠  Metadata embed failed: {e}")

    def _cancel(self):
        """Kill the running download and reset the UI."""
        proc = getattr(self, "_sp_proc", None)
        if proc and proc.poll() is None:
            try:
                proc.kill()
            except Exception:
                pass
        self._sp_proc = None
        self._cancel_btn.pack_forget()
        self.dl_btn.configure(state="normal", text="💾  Download")
        self._set_progress(0)
        self._set_status("🚫  Download cancelled.")
        self._log("— Cancelled by user —")

    def _done(self, save):
        push_folder_history("save_folder_spotify", save)
        self._cancel_btn.pack_forget()
        self.dl_btn.configure(state="normal", text="💾  Download")
        self._set_progress(1.0); self._set_status("✅  Done!")
        self._log(f"Saved to: {save}")
        _notify_done(save, self._open_folder, self._last_file)

    def _err(self, msg):
        self._cancel_btn.pack_forget()
        self.dl_btn.configure(state="normal", text="💾  Download")
        self._set_status("❌  Error — see log"); self._log(f"ERROR: {msg}")
        messagebox.showerror("Error", msg)


