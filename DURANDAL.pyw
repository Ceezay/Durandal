# Store all app data in %APPDATA%\MediaDownloader on Windows,
# ~/.local/share/MediaDownloader on Linux/macOS — never pollutes the script folder.
def _get_app_data_dir() -> Path:
    if platform.system() == "Windows":
        base = Path(os.environ.get("APPDATA", Path.home() / "AppData" / "Roaming"))
    elif platform.system() == "Darwin":
        base = Path.home() / "Library" / "Application Support"
    else:
        base = Path(os.environ.get("XDG_DATA_HOME", Path.home() / ".local" / "share"))
    d = base / "DURANDAL"
    d.mkdir(parents=True, exist_ok=True)
    return d

TOOLS_DIR  = _get_app_data_dir()
FFMPEG_DIR = TOOLS_DIR / "ffmpeg"

def _pip_install(pkg, imp=None):
    imp = imp or pkg
    try:
        __import__(imp)
        return
    except ImportError:
        pass
    print(f"[setup] Installing {pkg}...")
    subprocess.check_call(
        [sys.executable, "-m", "pip", "install", pkg, "-q"],
        stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL
    )

def _ffmpeg_exe():
    """Return path to a working ffmpeg binary, or None."""
    local = FFMPEG_DIR / ("ffmpeg.exe" if platform.system()=="Windows" else "ffmpeg")
    if local.exists():
        return local
    found = shutil.which("ffmpeg")
    return Path(found) if found else None

def _download_ffmpeg_windows():
    """Download a static FFmpeg build and extract ffmpeg.exe + ffprobe.exe."""
    FFMPEG_DIR.mkdir(parents=True, exist_ok=True)
    url = (
        "https://github.com/BtbN/FFmpeg-Builds/releases/download/latest/"
        "ffmpeg-master-latest-win64-gpl.zip"
    )
    zip_path = TOOLS_DIR / "ffmpeg_tmp.zip"
    print("[setup] Downloading FFmpeg (one-time, ~60 MB)...")
    urllib.request.urlretrieve(url, zip_path)
    print("[setup] Extracting...")
    with zipfile.ZipFile(zip_path, "r") as z:
        for member in z.namelist():
            fname = Path(member).name
            if fname in ("ffmpeg.exe", "ffprobe.exe"):
                with z.open(member) as src, open(FFMPEG_DIR / fname, "wb") as dst:
                    shutil.copyfileobj(src, dst)
    zip_path.unlink(missing_ok=True)
    exe = FFMPEG_DIR / "ffmpeg.exe"
    if not exe.exists():
        raise RuntimeError("FFmpeg extraction failed.")
    print("[setup] FFmpeg ready.")
    return exe

def _ensure_ffmpeg():
    exe = _ffmpeg_exe()
    if exe:
        return exe
    if platform.system() == "Windows":
        return _download_ffmpeg_windows()
    raise EnvironmentError(
        "FFmpeg not found.\nInstall it with:\n"
        "  macOS: brew install ffmpeg\n"
        "  Linux: sudo apt install ffmpeg"
    )

# ── Splash window shown during first-run setup ────────────────────────────────
def _bootstrap_with_splash():
    root = tk.Tk()
    root.title("DURANDAL — Setting up")
    root.geometry("440x150")
    root.resizable(False, False)
    root.configure(bg="#1a1a2e")
    try: root.eval("tk::PlaceWindow . center")
    except Exception: pass

    tk.Label(root, text="DURANDAL", bg="#1a1a2e", fg="white",
             font=("Segoe UI", 15, "bold")).pack(pady=(22,4))
    sv = tk.StringVar(value="Setting up for first use — please wait...")
    tk.Label(root, textvariable=sv, bg="#1a1a2e", fg="#aaaaaa",
             font=("Segoe UI", 10)).pack()

    canvas = tk.Canvas(root, bg="#1a1a2e", highlightthickness=0, width=380, height=10)
    canvas.pack(pady=14)
    bar = canvas.create_rectangle(0, 0, 0, 10, fill="#4f9eff", outline="")
    result = {"ffmpeg": None, "error": None, "done": False}

    def _animate():
        if result["done"]: return
        coords = canvas.coords(bar)
        new_w  = min(coords[2] + 5, 370)
        canvas.coords(bar, 0, 0, new_w, 10)
        root.after(100, _animate)

    def _worker():
        try:
            sv.set("Installing Python libraries...")
            for pkg, imp in [("yt-dlp","yt_dlp"),("customtkinter","customtkinter"),("spotdl","spotdl"),("Pillow","PIL")]:
                _pip_install(pkg, imp)
            sv.set("Fetching FFmpeg...")
            result["ffmpeg"] = _ensure_ffmpeg()
            sv.set("All done!")
        except Exception as exc:
            result["error"] = str(exc)
        finally:
            result["done"] = True
            root.after(600, root.destroy)

    _animate()
    threading.Thread(target=_worker, daemon=True).start()
    root.mainloop()
    return result["ffmpeg"], result["error"]

# ── Desktop shortcut ──────────────────────────────────────────────────────────
SHORTCUT_FLAG = TOOLS_DIR / ".shortcut_created"

def _create_desktop_shortcut():
    """
    Create a Desktop .lnk via a temporary VBScript run silently with wscript.
    No PowerShell, no COM imports needed. Fast and reliable.
    Returns (True, "") on success or (False, reason) on failure.
    """
    if platform.system() != "Windows":
        return False, "Not Windows"
    try:
        import ctypes, ctypes.wintypes, tempfile

        # Resolve paths — works both as .pyw script and as a PyInstaller .exe
        if getattr(sys, "frozen", False):
            # Running as a PyInstaller bundle — shortcut points to the .exe itself
            script_path = str(Path(sys.executable).resolve())
            pythonw = Path(sys.executable)
        else:
            script_path = str(Path(__file__).resolve())
            pythonw = Path(sys.executable).parent / "pythonw.exe"
            if not pythonw.exists():
                pythonw = Path(sys.executable)

        # Resolve real Desktop (handles OneDrive redirection)
        buf = ctypes.create_unicode_buffer(ctypes.wintypes.MAX_PATH)
        ctypes.windll.shell32.SHGetFolderPathW(0, 0, 0, 0, buf)
        desktop  = Path(buf.value) if buf.value else Path.home() / "Desktop"
        lnk_path = str(desktop / "DURANDAL.lnk")

        # Write a tiny VBScript to a temp file
        app_name = "DURANDAL"
        vbs_lines = [
            'Set ws = CreateObject("WScript.Shell")',
            f'Set s = ws.CreateShortcut("{lnk_path}")',
            f's.TargetPath = "{str(pythonw)}"',
            *([] if getattr(sys, "frozen", False) else [f's.Arguments = Chr(34) & "{script_path}" & Chr(34)']),  # not needed when running as .exe
            f's.WorkingDirectory = "{str(Path(script_path).parent)}"',
            f's.Description = "{app_name}"',
            's.Save',
        ]
        vbs_text = "\r\n".join(vbs_lines)

        with tempfile.NamedTemporaryFile(mode="w", suffix=".vbs",
                                         delete=False, encoding="utf-8") as tmp:
            tmp.write(vbs_text)
            tmp_path = tmp.name

        CREATE_NO_WINDOW = 0x08000000
        r = subprocess.run(
            ["wscript", "//Nologo", "//B", tmp_path],
            capture_output=True,
            creationflags=CREATE_NO_WINDOW,
            timeout=10
        )
        try:
            Path(tmp_path).unlink()
        except Exception:
            pass

        if r.returncode == 0 and Path(lnk_path).exists():
            SHORTCUT_FLAG.touch()
            return True, ""
        err = r.stderr.decode(errors="ignore").strip()
        return False, err or f"wscript returned code {r.returncode}"

    except Exception as e:
        return False, str(e)

def _needs_setup():
    if _ffmpeg_exe() is None:
        return True
    for imp in ("yt_dlp", "customtkinter", "spotdl", "PIL"):
        try: __import__(imp)
        except ImportError: return True
    return False

if _needs_setup():
    _ffmpeg_path, _setup_err = _bootstrap_with_splash()
else:
    try:
        _ffmpeg_path = _ensure_ffmpeg()
        _setup_err   = None
    except Exception as e:
        _ffmpeg_path, _setup_err = None, str(e)

if _setup_err:
    _r = tk.Tk(); _r.withdraw()
    messagebox.showerror("Setup failed", _setup_err)
    _r.destroy()
    sys.exit(1)

