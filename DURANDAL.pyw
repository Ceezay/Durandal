# ── Load custom font from embedded base64 ────────────────────────────────────
def _load_custom_fonts():
    """Decode embedded fonts, write to TOOLS_DIR/fonts/, return (path1, path2)."""
    try:
        import base64 as _b64
        _font_dir = TOOLS_DIR / "fonts"
        _font_dir.mkdir(parents=True, exist_ok=True)
        p1 = _font_dir / "IvyPrestoHeadlineLight.otf"
        p2 = _font_dir / "PPFraktionMono-Regular.otf"
        if not p1.exists():
            p1.write_bytes(_b64.b64decode(_FONT_B64))
        if not p2.exists():
            p2.write_bytes(_b64.b64decode(_FONT2_B64))
        return str(p1), str(p2)
    except Exception:
        return "", ""

_CUSTOM_FONT_PATH, _CUSTOM_FONT2_PATH = _load_custom_fonts()

def _register_font(root) -> tuple:
    """Register both fonts via GDI32 on Windows. Returns (title_family, ui_family)."""
    title_family = "Segoe UI"
    ui_family    = "Segoe UI"
    try:
        from ctypes import windll
        FR_PRIVATE = 0x10
        if _CUSTOM_FONT_PATH:
            windll.gdi32.AddFontResourceExW(_CUSTOM_FONT_PATH,  FR_PRIVATE, 0)
            title_family = "IvyPresto Headline Light"
        if _CUSTOM_FONT2_PATH:
            windll.gdi32.AddFontResourceExW(_CUSTOM_FONT2_PATH, FR_PRIVATE, 0)
            ui_family = "PP Fraktion Mono"
    except Exception:
        pass
    return title_family, ui_family


