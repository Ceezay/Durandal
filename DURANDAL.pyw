def _notify_done(save, open_fn, last_file: str = None):
    """Respect user prefs for popup and auto-open after download."""
    auto_open = get_pref("auto_open_folder")
    notify    = get_pref("notify_on_done")
    # Use last_file for highlight if available, else fall back to folder
    target = last_file if (last_file and Path(last_file).exists()) else save
    if auto_open:
        _open_and_highlight(target)
    elif notify:
        if messagebox.askyesno("Done!", "Download complete!\n\nOpen folder?"):
            _open_and_highlight(target)

def _to_sec(s):
    s = s.strip()
    if not s: return None
    try:
        parts = [float(x) for x in s.split(":")]
        if len(parts)==1: return parts[0]
        if len(parts)==2: return parts[0]*60+parts[1]
        if len(parts)==3: return parts[0]*3600+parts[1]*60+parts[2]
    except ValueError: pass
    return None

def _fmt_sec(sec):
    sec=int(sec); h,r=divmod(sec,3600); m,s=divmod(r,60)
    return f"{h:02d}:{m:02d}:{s:02d}"

