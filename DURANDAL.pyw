            state="normal"  if active else "disabled",
            text_color="white" if active else "gray50")
        self._fn_clear_btn.configure(state="normal" if active else "disabled")
        if active:
            self._filename_entry.focus_set()
        else:
            # Unticked — restore the original hint if the entry was left empty
            hint = getattr(self, "_last_filename_hint", "")
            if hint and not self._filename_entry.get().strip():
                self._filename_entry.configure(state="normal")
                self._filename_entry.delete(0, "end")
                self._filename_entry.insert(0, hint)
                self._filename_entry.configure(state="disabled", text_color="gray50")

    def _clear_filename(self):
        self._filename_entry.delete(0, "end")
        self._filename_entry.focus_set()

    def _get_outtmpl(self, save):
        """Return yt-dlp outtmpl string, using custom name if set."""
        custom = self._filename_entry.get().strip() if self._custom_name_var.get() else ""
        if custom:
            return str(Path(save) / f"{custom}.%(ext)s")
        return str(Path(save) / "%(uploader)s - %(title).60s.%(ext)s")

    # ── Fetch info ────────────────────────────────────────────────────────────
    def _fetch(self):
        url = self.url_entry.get().strip()
        if not url: return
        # Normalise twitter.com → x.com
        url = url.replace("twitter.com", "x.com")
        self.url_entry.delete(0, "end")
        self.url_entry.insert(0, url)
        self.fetch_btn.configure(state="disabled", text="Loading…")
        self.dl_btn.configure(state="disabled")
        self.info_lbl.configure(text="Fetching info…", text_color="gray55")
        threading.Thread(target=self._do_fetch, args=(url,), daemon=True).start()

    def _do_fetch(self, url):
        import yt_dlp
        try:
            opts = {
                "quiet": True, "no_warnings": True,
                "skip_download": True,
                "ffmpeg_location": str(_ffmpeg_path),
                "socket_timeout": 15,
            }
            with yt_dlp.YoutubeDL(opts) as ydl:
                info = ydl.extract_info(url, download=False)

            title    = info.get("title") or info.get("description") or "X Video"
            uploader = info.get("uploader") or info.get("uploader_id") or "?"
            dur      = info.get("duration")
            dur_s    = _fmt_sec(float(dur)) if dur else "?"

            # Available heights for display
            fmts     = info.get("formats") or []
            heights  = sorted({f.get("height") for f in fmts if f.get("height")}, reverse=True)
            res_str  = "  |  " + ", ".join(f"{h}p" for h in heights[:4]) if heights else ""

            self.after(0, lambda t=title: self._set_filename_hint(t))
            self.after(0, lambda: (
                self.info_lbl.configure(
                    text=f'🐦  "{title[:60]}"  @{uploader}  |  {dur_s}{res_str}',
                    text_color="#4fc3f7"),
                self.fetch_btn.configure(state="normal", text="Load Info"),
                self.dl_btn.configure(state="normal")
            ))
        except Exception as e:
            err = str(e).splitlines()[-1][:140]
            self.after(0, lambda: (
                self.info_lbl.configure(text=f"⚠  {err}", text_color="#ff6b6b"),
                self.fetch_btn.configure(state="normal", text="Load Info"),
                self.dl_btn.configure(state="disabled")
            ))

    # ── Download ──────────────────────────────────────────────────────────────
    def _start(self):
        url  = self.url_entry.get().strip()
        save = self.save_var.get().strip()
        if not url:
            messagebox.showwarning("No URL", "Please enter an X video URL."); return
        if not save:
            messagebox.showwarning("No folder", "Please choose a save folder."); return
        set_pref("save_folder_x", save)
        if not self._confirm_download("X download"): return
        self._maybe_clear_log()
        self.dl_btn.configure(state="disabled", text="Downloading…")
        self._set_status("Starting download…")
        self._set_progress(0)
        threading.Thread(target=self._do_download, args=(url, save), daemon=True).start()

    def _do_download(self, url, save):
        import yt_dlp
        q     = self.quality_var.get()
        q_map = {
            "Best available": "bestvideo[ext=mp4]+bestaudio[ext=m4a]/best[ext=mp4]/best",
            "1080p":  "bestvideo[height<=1080][ext=mp4]+bestaudio[ext=m4a]/best[height<=1080]",
            "720p":   "bestvideo[height<=720][ext=mp4]+bestaudio[ext=m4a]/best[height<=720]",
            "480p":   "bestvideo[height<=480][ext=mp4]+bestaudio[ext=m4a]/best[height<=480]",
            "360p":   "bestvideo[height<=360][ext=mp4]+bestaudio[ext=m4a]/best[height<=360]",
        }
        opts = {
            "format":           q_map.get(q, "best"),
            "outtmpl":          self._get_outtmpl(save),
            "ffmpeg_location":  str(_ffmpeg_path),
            "merge_output_format": "mp4",
            "progress_hooks":   [self._progress_hook],
            "quiet":            True,
            "no_warnings":      True,
            "postprocessors":   [{"key": "FFmpegVideoConvertor", "preferedformat": "mp4"}],
        }
        try:
            with yt_dlp.YoutubeDL(opts) as ydl:
                ydl.download([url])
            self.after(0, self._done, save)
        except Exception as exc:
            self.after(0, self._err, str(exc))

    def _done(self, save):
        push_folder_history("save_folder_x", save)
        self.dl_btn.configure(state="normal", text="💾  Download")
        self._set_progress(1.0); self._set_status("✅  Done!")
        self._log(f"Saved to: {save}")
        _notify_done(save, self._open_folder, self._last_file)

    def _err(self, msg):
        self.dl_btn.configure(state="normal", text="💾  Download")
        self._set_status("❌  Error — see log"); self._log(f"ERROR: {msg}")
        messagebox.showerror("Error", msg)


# ─────────────────────────────────────────────────────────────────────────────
