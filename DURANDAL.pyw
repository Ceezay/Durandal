    # ── Browse ───────────────────────────────────────────────────────────────
    def _browse(self):
        from tkinter import filedialog as _fd
        path = _fd.askopenfilename(
            title="Select image or GIF",
            filetypes=[("Images & GIFs", "*.png *.jpg *.jpeg *.webp *.gif *.bmp *.tiff"),
                       ("All files", "*.*")]
        )
        if not path:
            return
        self._load(path)

    def _load(self, path):
        from PIL import Image as _PILImage
        # Cancel any running animation first
        if self._anim_job:
            self.after_cancel(self._anim_job)
            self._anim_job = None
        self._src_path    = path
        self._src_frames  = []
        self._anim_delays = []
        self._anim_idx    = 0
        img = _PILImage.open(path)
        n_frames = getattr(img, "n_frames", 1)
        try:
            for i in range(n_frames):
                img.seek(i)
                self._src_frames.append(img.copy().convert("RGBA"))
                delay = img.info.get("duration", 100)
                self._anim_delays.append(max(20, int(delay)))
        except EOFError:
            pass
        if not self._src_frames:
            self._src_frames = [img.convert("RGBA")]
            self._anim_delays = [100]
        self._is_gif  = len(self._src_frames) > 1
        self._src_img = self._src_frames[0]
        w, h = self._src_img.size
        init_sz = int(min(w, h) * 0.8)
        self._crop_x  = (w - init_sz) // 2
        self._crop_y  = (h - init_sz) // 2
        self._crop_sz = init_sz
        self._zoom  = 1.0
        self._pan_x = 0.0
        self._pan_y = 0.0
        # Update button text to match file type
        label = "💾  Download"
        self._dl_btn.configure(state="normal", text=label)
        # Show FPS row only for GIFs
        if self._is_gif:
            self._gif_fps_var.set("Original")
            self._fps_row.pack(fill="x", padx=18, pady=(0,4), before=self._canvas)
        else:
            self._fps_row.pack_forget()
        self._redraw()
        if self._is_gif:
            self._animate()

    # ── GIF animation loop ────────────────────────────────────────────────
    def _reset_adjustments(self):
        for var, neutral in [
            (self._adj_brightness, 1.0),
            (self._adj_contrast,   1.0),
            (self._adj_saturation, 1.0),
            (self._adj_sharpness,  1.0),
        ]:
            var.set(neutral)
        self._redraw()

    def _on_fps_change(self):
        """Restart the animation loop when the FPS dropdown changes."""
        if self._anim_job:
            self.after_cancel(self._anim_job)
            self._anim_job = None
        if self._is_gif:
            self._animate()

    def _current_delay(self, idx):
        """Return the delay in ms for frame idx, respecting the FPS override."""
        fps_str = self._gif_fps_var.get()
        if fps_str == "Original":
            return self._anim_delays[idx] if self._anim_delays else 100
        fps = float(fps_str)
        return max(20, int(1000 / fps))

    def _animate(self):
        if not self._is_gif or not self._src_frames:
            return
        self._anim_idx = (self._anim_idx + 1) % len(self._src_frames)
        self._src_img  = self._src_frames[self._anim_idx]
        self._redraw()
        delay = self._current_delay(self._anim_idx)
        self._anim_job = self.after(delay, self._animate)

    # ── Drawing ──────────────────────────────────────────────────────────────
    def _on_resize(self, event=None):
        # Ignore spurious Configure events during settings panel open/close
        if event and hasattr(event, "width") and event.width < 200:
            return
        self._redraw()

    def _redraw(self):
        if self._src_img is None:
            return
        from PIL import Image as _PILImage, ImageTk as _ImageTk, ImageDraw as _ImageDraw

        cw = self._canvas.winfo_width()
        ch = self._canvas.winfo_height()
        if cw < 10 or ch < 10:
            return

        iw, ih = self._src_img.size
        # base fit-scale so image fills the canvas, then apply user zoom
        fit_scale = min(cw / iw, ch / ih, 1.0)
        scale = fit_scale * self._zoom
        dw = max(1, int(iw * scale))
        dh = max(1, int(ih * scale))
        self._scale = scale
        self._disp_w = dw
        self._disp_h = dh

        # centre-of-canvas offset + user pan, clamped so image edge stays visible
        cx_base = (cw - dw) / 2
        cy_base = (ch - dh) / 2
        # clamp pan so we can't pan entirely off-screen
        max_px = max(0, (dw - cw) / 2 + dw * 0.1)
        max_py = max(0, (dh - ch) / 2 + dh * 0.1)
        self._pan_x = max(-max_px, min(self._pan_x, max_px))
        self._pan_y = max(-max_py, min(self._pan_y, max_py))
        ox = int(cx_base + self._pan_x)
        oy = int(cy_base + self._pan_y)
        self._img_ox = ox
        self._img_oy = oy

        # resize source image for display and apply adjustments
        disp = self._src_img.resize((dw, dh), _PILImage.LANCZOS)
        disp = self._apply_adjustments(disp)

        # ── draw translucent overlay with crop hole ──────────────────────────
        overlay = _PILImage.new("RGBA", (dw, dh), (0, 0, 0, 140))
        draw    = _ImageDraw.Draw(overlay)

        # crop box in display coords
        cx = int(self._crop_x * scale)
        cy = int(self._crop_y * scale)
        cs = int(self._crop_sz * scale)
        cs = max(cs, 10)

        # cut the crop area out of overlay (transparent = shows through)
        if self._shape.get() == "circle":
            draw.ellipse([cx, cy, cx + cs, cy + cs], fill=(0, 0, 0, 0))
        else:
            draw.rectangle([cx, cy, cx + cs, cy + cs], fill=(0, 0, 0, 0))

        composite = _PILImage.alpha_composite(disp.convert("RGBA"), overlay)

        # ── draw crop border ─────────────────────────────────────────────────
        border_draw = _ImageDraw.Draw(composite)
        bx1, by1, bx2, by2 = cx, cy, cx + cs, cy + cs
        if self._shape.get() == "circle":
            border_draw.ellipse([bx1, by1, bx2, by2], outline="#ffffff", width=2)
        else:
            border_draw.rectangle([bx1, by1, bx2, by2], outline="#ffffff", width=2)

        # ── resize handle (bottom-right corner) ─────────────────────────────
        hr = 7  # handle radius
        hx, hy = bx2, by2
        border_draw.ellipse([hx - hr, hy - hr, hx + hr, hy + hr],
                             fill="#5865F2", outline="#ffffff", width=1)

        # ── centring crosshair (dashed yellow lines through crop centre) ─
        if self._show_grid.get():
            mid_x = cx + cs // 2
            mid_y = cy + cs // 2
            dash_pat = (6, 4)
            border_draw.line([cx, mid_y, cx + cs, mid_y],
                             fill="#ffff00", width=1)
            border_draw.line([mid_x, cy, mid_x, cy + cs],
                             fill="#ffff00", width=1)
            # make them dashed by overdrawing gaps in background colour
            dash_len, gap_len = 8, 5
            for start in range(cx, cx + cs, dash_len + gap_len):
                end = min(start + gap_len, cx + cs)
                border_draw.line([start, mid_y, end, mid_y],
                                 fill=(0, 0, 0, 0), width=1)
            for start in range(cy, cy + cs, dash_len + gap_len):
                end = min(start + gap_len, cy + cs)
                border_draw.line([mid_x, start, mid_x, end],
                                 fill=(0, 0, 0, 0), width=1)

        self._tk_preview = _ImageTk.PhotoImage(composite)
        self._canvas.delete("all")
        self._canvas.create_image(ox, oy, anchor="nw", image=self._tk_preview)

        # ── live size previews (bottom-right of canvas) ─────────────────
        self._preview_imgs = []   # keep refs so GC doesn't collect them
        preview_sizes = [s for s in self.EXPORT_SIZES if s <= 128]
        padding = 8
        px = cw - padding
        py = ch - padding
        for psz in preview_sizes:
            # crop + resize to preview size
            x0p = int(self._crop_x)
            y0p = int(self._crop_y)
            szp = int(self._crop_sz)
            frame = self._src_img.crop((x0p, y0p, x0p + szp, y0p + szp))
            frame = self._apply_quality_effect(frame.convert("RGBA"), psz)
            if self._shape.get() == "circle":
                from PIL import ImageDraw as _ID2
                mask = _PILImage.new("L", (psz, psz), 0)
                _ID2.Draw(mask).ellipse([0, 0, psz, psz], fill=255)
                out = _PILImage.new("RGBA", (psz, psz), (0, 0, 0, 0))
                out.paste(frame, mask=mask)
                frame = out
            tk_img = _ImageTk.PhotoImage(frame)
            self._preview_imgs.append(tk_img)
            # draw right-aligned, stacked bottom-to-top
            px_left = px - psz
            py_top  = py - psz
            # dark backing rect
            self._canvas.create_rectangle(
                px_left - 3, py_top - 3, px + 3, py + 3,
                fill="#1a1a1a", outline="#444444")
            self._canvas.create_image(px_left, py_top, anchor="nw", image=tk_img)
            # size label
            self._canvas.create_text(
                px_left + psz // 2, py_top - 5,
                text=f"{psz}px", fill="#888888",
                font=("", 8), anchor="s")
            px = px_left - padding

    # ── Drag logic ────────────────────────────────────────────────────────────
    def _canvas_to_img(self, cx, cy):
        """Convert canvas pixel → image pixel."""
        ix = (cx - self._img_ox) / self._scale
        iy = (cy - self._img_oy) / self._scale
        return ix, iy

    def _on_press(self, event):
        ix, iy = self._canvas_to_img(event.x, event.y)
        # check resize handle (bottom-right of crop box) first
        hx = self._crop_x + self._crop_sz
        hy = self._crop_y + self._crop_sz
        if abs(ix - hx) <= 12 / self._scale and abs(iy - hy) <= 12 / self._scale:
            self._drag_mode = "resize"
        elif (self._crop_x <= ix <= self._crop_x + self._crop_sz and
              self._crop_y <= iy <= self._crop_y + self._crop_sz):
            self._drag_mode = "move"
            self._drag_ox = ix - self._crop_x
            self._drag_oy = iy - self._crop_y
        else:
            self._drag_mode = None

    def _on_drag(self, event):
        if self._drag_mode is None or self._src_img is None:
            return
        ix, iy = self._canvas_to_img(event.x, event.y)
        iw, ih = self._src_img.size
        if self._drag_mode == "move":
            nx = ix - self._drag_ox
            ny = iy - self._drag_oy
            # clamp
            nx = max(0, min(nx, iw - self._crop_sz))
            ny = max(0, min(ny, ih - self._crop_sz))
            self._crop_x = nx
            self._crop_y = ny
        elif self._drag_mode == "resize":
            new_sz = int(max(32, ix - self._crop_x, iy - self._crop_y))
            max_sz = int(min(iw - self._crop_x, ih - self._crop_y))
            self._crop_sz = min(new_sz, max_sz)
        self._redraw()

    def _on_release(self, event):
        self._drag_mode = None

    def _on_scroll(self, event):
        """Zoom in/out centred on the mouse cursor position."""
        if self._src_img is None:
            return
        # determine scroll direction
        if hasattr(event, "delta") and event.delta != 0:
            direction = 1 if event.delta > 0 else -1
        elif event.num == 4:
            direction = 1
        elif event.num == 5:
            direction = -1
        else:
            return
        factor = 1.12 if direction > 0 else (1 / 1.12)
        new_zoom = self._zoom * factor
        # clamp zoom: 0.5× to 8×
        new_zoom = max(0.5, min(new_zoom, 8.0))
        if new_zoom == self._zoom:
            return
        # adjust pan so the point under the cursor stays fixed
        # cursor in canvas coords
        mx = event.x
        my = event.y
        # image pixel under cursor before zoom
        ix = (mx - self._img_ox) / self._scale
        iy = (my - self._img_oy) / self._scale
        self._zoom = new_zoom
        # recalculate where that image pixel will land after zoom
        iw, ih = self._src_img.size
        cw = self._canvas.winfo_width()
        ch = self._canvas.winfo_height()
        fit_scale = min(cw / iw, ch / ih, 1.0)
        new_scale = fit_scale * self._zoom
        new_dw = max(1, int(iw * new_scale))
        new_dh = max(1, int(ih * new_scale))
        new_cx_base = (cw - new_dw) / 2
        new_cy_base = (ch - new_dh) / 2
        # desired offset: image pixel ix lands at canvas x mx
        desired_ox = mx - ix * new_scale
        desired_oy = my - iy * new_scale
        self._pan_x = desired_ox - new_cx_base
        self._pan_y = desired_oy - new_cy_base
        self._redraw()

    # ── Adjustment helper ─────────────────────────────────────────────────────
    def _apply_adjustments(self, img):
        """Apply brightness/contrast/saturation/sharpness to a PIL RGBA image."""
        from PIL import ImageEnhance as _IE
        base = img.convert("RGB")
        base = _IE.Brightness(base).enhance(self._adj_brightness.get())
        base = _IE.Contrast(base).enhance(self._adj_contrast.get())
        base = _IE.Color(base).enhance(self._adj_saturation.get())
        base = _IE.Sharpness(base).enhance(self._adj_sharpness.get())
        result = base.convert("RGBA")
        if img.mode == "RGBA":
            result.putalpha(img.split()[3])
        return result

    # ── Quality effect helper ─────────────────────────────────────────────────
    def _on_quality_change(self, value):
        """Called when quality dropdown changes. Guard separator rows; open popup for Custom."""
        if value.startswith("──"):
            # Revert to previous sensible value (Best) if a separator was clicked
            self._quality_var.set("Best")
            return
        if value == "Custom…":
            self._open_custom_adj_window()
            return
        self._redraw()

    def _open_custom_adj_window(self):
        """Open (or re-raise) the Custom adjustments popup window."""
        if self._adj_win is not None:
            try:
                self._adj_win.lift()
                self._adj_win.focus_force()
                return
            except Exception:
                self._adj_win = None

        win = ctk.CTkToplevel(self)
        win.title("Custom Adjustments")
        win.geometry("440x380")
        win.resizable(False, False)
        win.grab_set()
        self._adj_win = win

        def _on_close():
            self._adj_win = None
            win.destroy()

        win.protocol("WM_DELETE_WINDOW", _on_close)

        ctk.CTkLabel(win, text="Custom Adjustments",
                     font=ctk.CTkFont(size=14, weight="bold")).pack(pady=(14, 4))

        body = ctk.CTkFrame(win, fg_color="transparent")
        body.pack(fill="both", expand=True, padx=18, pady=(0, 6))

        def _adj_row(parent, label, var, from_, to, neutral=None):
            row = ctk.CTkFrame(parent, fg_color="transparent")
            row.pack(fill="x", pady=(4, 0))
            ctk.CTkLabel(row, text=label, width=78, anchor="w",
                         font=ctk.CTkFont(size=11)).pack(side="left")
            sl = ctk.CTkSlider(row, variable=var, from_=from_, to=to,
                               width=240, height=14,
                               fg_color="#333", progress_color=DC_ACCENT,
                               button_color=DC_ACCENT, button_hover_color=DC_HOVER,
                               command=lambda _: self._redraw())
            sl.pack(side="left", padx=(4, 6))
            val_lbl = ctk.CTkLabel(row, text="", width=38,
                                   font=ctk.CTkFont(size=10), anchor="w")
            val_lbl.pack(side="left")
            def _upd(*_, v=var, l=val_lbl, lb=label):
                val = v.get()
                l.configure(text=f"{val:+.0f}°" if lb == "Hue" else f"{val:.2f}")
            var.trace_add("write", _upd); _upd()
            if neutral is not None:
                ctk.CTkButton(row, text="↺", width=26, height=20,
                              fg_color="#333", hover_color="#555",
                              font=ctk.CTkFont(size=11),
                              command=lambda v=var, n=neutral: (v.set(n), self._redraw())
                              ).pack(side="left")

        _adj_row(body, "Brightness", self._adj_brightness, 0.1, 3.0, 1.0)
        _adj_row(body, "Contrast",   self._adj_contrast,   0.1, 3.0, 1.0)
        _adj_row(body, "Saturation", self._adj_saturation, 0.0, 3.0, 1.0)
        _adj_row(body, "Sharpness",  self._adj_sharpness,  0.0, 3.0, 1.0)

        btn_row = ctk.CTkFrame(win, fg_color="transparent")
        btn_row.pack(fill="x", padx=18, pady=(4, 14))
        ctk.CTkButton(btn_row, text="Reset all", width=100, height=28,
                      fg_color="transparent", border_width=1, border_color="#555",
                      command=lambda: (self._reset_adjustments(), self._redraw())
                      ).pack(side="left")
        ctk.CTkButton(btn_row, text="Close", width=100, height=28,
                      fg_color=DC_ACCENT, hover_color=DC_HOVER,
                      command=_on_close).pack(side="right")

    def _apply_quality_effect(self, img, target_size):
        """Resize img to target_size applying current quality setting."""
        from PIL import Image as _PI, ImageFilter as _IF, ImageEnhance as _IE
        import random as _rnd
        q = self._quality_var.get()
        # Apply adjustments to source before effect
        img = self._apply_adjustments(img)

        # Separators and Custom… fall through to standard resize
        if q.startswith("──") or q == "Custom…":
            q = "Best"

        if q == "8-Bit 👾":
            tiny = img.resize((16, 16), _PI.NEAREST)
            return tiny.resize((target_size, target_size), _PI.NEAREST)

        elif q == "Tiny 🔬":
            tiny = img.resize((8, 8), _PI.NEAREST)
            return tiny.resize((target_size, target_size), _PI.NEAREST)

        elif q == "Fried 🍳":
            import io
            base = img.resize((target_size, target_size), _PI.LANCZOS)
            rgb = base.convert("RGB")
            rgb = _IE.Color(rgb).enhance(4.0)
            rgb = _IE.Contrast(rgb).enhance(3.0)
            rgb = _IE.Brightness(rgb).enhance(1.4)
            for _ in range(6):
                rgb = rgb.filter(_IF.SHARPEN)
            buf = io.BytesIO()
            rgb.save(buf, format="JPEG", quality=2, subsampling=2)
            buf.seek(0)
            return _PI.open(buf).convert("RGBA")

        elif q == "Nuke ☢️":
            import io
            base = img.resize((target_size, target_size), _PI.LANCZOS).convert("RGB")
            for _ in range(3):
                buf = io.BytesIO()
                base.save(buf, format="JPEG", quality=1, subsampling=2)
                buf.seek(0)
                base = _PI.open(buf).convert("RGB")
            return base.convert("RGBA")


        elif q == "Vintage 📼":
            base = img.resize((target_size, target_size), _PI.LANCZOS).convert("RGB")
            r, g, b = base.split()
            r = _IE.Brightness(r).enhance(1.1)
            g = _IE.Brightness(g).enhance(0.9)
            b = _IE.Brightness(b).enhance(0.7)
            sepia = _PI.merge("RGB", (r, g, b))
            sepia = _IE.Contrast(sepia).enhance(0.8)
            # vignette
            import math
            vign = _PI.new("L", (target_size, target_size), 0)
            cx, cy = target_size / 2, target_size / 2
            pix = vign.load()
            for yy in range(target_size):
                for xx in range(target_size):
                    d = math.hypot(xx - cx, yy - cy) / (target_size * 0.7)
                    pix[xx, yy] = int(min(255, d * d * 180))
            sepia = sepia.convert("RGBA")
            dark  = _PI.new("RGBA", (target_size, target_size), (0, 0, 0, 0))
            sepia.paste(dark, mask=vign)
            return sepia

        elif q == "Noir 🕵️":
            base = img.resize((target_size, target_size), _PI.LANCZOS).convert("L")
            base = _IE.Contrast(base).enhance(3.0)
            base = _IE.Brightness(base).enhance(0.85)
            return base.convert("RGBA")

        elif q == "Mirror 🪞":
            half = target_size // 2
            quad = img.resize((half, half), _PI.LANCZOS).convert("RGBA")
            out  = _PI.new("RGBA", (target_size, target_size))
            out.paste(quad,                           (0,    0))
            out.paste(quad.transpose(_PI.FLIP_LEFT_RIGHT), (half, 0))
            out.paste(quad.transpose(_PI.FLIP_TOP_BOTTOM), (0,    half))
            out.paste(quad.transpose(_PI.FLIP_LEFT_RIGHT).transpose(_PI.FLIP_TOP_BOTTOM),
                      (half, half))
            return out

        elif q == "Oil Painting 🖌️":
            base = img.resize((target_size, target_size), _PI.LANCZOS).convert("RGB")
            base = base.filter(_IF.GaussianBlur(radius=2))
            from PIL import ImageOps as _IO
            base = _IO.posterize(base, 3)
            base = base.filter(_IF.SMOOTH_MORE)
            return base.convert("RGBA")

        elif q == "Impressionist 🎨":
            base = img.resize((target_size, target_size), _PI.LANCZOS).convert("RGB")
            blurred = base.filter(_IF.GaussianBlur(radius=4))
            edges   = base.filter(_IF.FIND_EDGES).convert("RGB")
            edges   = _IE.Brightness(edges).enhance(3.0)
            result  = _PI.blend(blurred, edges, alpha=0.45)
            result  = _IE.Color(result).enhance(2.5)
            return result.convert("RGBA")

        elif q == "Deep Dream 🌀":
            base = img.resize((target_size, target_size), _PI.LANCZOS).convert("RGB")
            emboss = base.filter(_IF.EMBOSS)
            tinted = _IE.Color(_PI.blend(base, emboss, 0.6)).enhance(2.0)
            for _ in range(2):
                tinted = tinted.filter(_IF.SHARPEN)
            return tinted.convert("RGBA")


        else:
            filter_map = {
                "Best":   _PI.LANCZOS,
                "High":   _PI.BICUBIC,
                "Medium": _PI.BILINEAR,
                "Low":    _PI.NEAREST,
            }
            f = filter_map.get(q, _PI.LANCZOS)
            return img.resize((target_size, target_size), f)

    # ── Export ────────────────────────────────────────────────────────────────
    def _export(self):
        if self._src_img is None:
            return
        from tkinter import filedialog as _fd
        from PIL import Image as _PILImage, ImageDraw as _ImageDraw
        import os

        export_sz = int(self._size_var.get())
        # PNG/GIF file-size settings
        q = self._quality_var.get()
        png_compress_map = {"Best": 1, "High": 4, "Medium": 6, "Low": 9,
                            "8-Bit 👾": 9, "Fried 🍳": 6, "Nuke ☢️": 9,
                            "Vintage 📼": 5, "Noir 🕵️": 4,
                            "Mirror 🪞": 3, "Oil Painting 🖌️": 5,
                            "Impressionist 🎨": 4, "Deep Dream 🌀": 4,
                            "Tiny 🔬": 9, "Custom…": 1}
        gif_colors_map   = {"Best": 256, "High": 200, "Medium": 128, "Low": 64,
                            "8-Bit 👾": 16, "Fried 🍳": 128, "Nuke ☢️": 32,
                            "Vintage 📼": 128, "Noir 🕵️": 64,
                            "Mirror 🪞": 256, "Oil Painting 🖌️": 64,
                            "Impressionist 🎨": 200, "Deep Dream 🌀": 200,
                            "Tiny 🔬": 8, "Custom…": 256}
        png_compress = png_compress_map.get(q, 1)
        gif_colors   = gif_colors_map.get(q, 256)
        is_circle = self._shape.get() == "circle"
        is_gif    = len(self._src_frames) > 1

        # crop box bounds
        x0 = int(self._crop_x)
        y0 = int(self._crop_y)
        sz = int(self._crop_sz)
        iw, ih = self._src_img.size

        # suggest filename
        stem = os.path.splitext(os.path.basename(self._src_path or "avatar"))[0]
        ext  = ".gif" if is_gif else ".png"
        default = f"{stem}_avatar_{export_sz}{ext}"

        out_path = _fd.asksaveasfilename(
            title="Save avatar",
            initialfile=default,
            defaultextension=ext,
            filetypes=[("PNG", "*.png"), ("GIF", "*.gif"), ("All", "*.*")]
        )
        if not out_path:
            return

        def _crop_frame(frame):
            cropped = frame.crop((x0, y0, x0 + sz, y0 + sz)).convert("RGBA")
            cropped = self._apply_quality_effect(cropped, export_sz)
            if is_circle:
                mask = _PILImage.new("L", (export_sz, export_sz), 0)
                _ImageDraw.Draw(mask).ellipse([0, 0, export_sz, export_sz], fill=255)
                out = _PILImage.new("RGBA", (export_sz, export_sz), (0, 0, 0, 0))
                out.paste(cropped, mask=mask)
                return out
            return cropped

        try:
            if is_gif:
                frames = [_crop_frame(f) for f in self._src_frames]
                fps_str = self._gif_fps_var.get()
                if fps_str == "Original":
                    durations = [max(20, d) for d in self._anim_delays] or [100]
                else:
                    frame_ms = max(20, int(1000 / float(fps_str)))
                    durations = [frame_ms] * len(frames)
                frames[0].save(out_path, save_all=True, append_images=frames[1:],
                                loop=0, format="GIF", colors=gif_colors,
                                duration=durations)
            else:
                _crop_frame(self._src_img).save(out_path, format="PNG", compress_level=png_compress)
            self._dl_status.configure(text=f"✅  Saved  {export_sz}×{export_sz} px")
        except Exception as e:
            self._dl_status.configure(text=f"❌  {e}")


