        self._filename_entry.focus_set()

    def _get_save_name(self, fallback):
        if self._custom_name_var.get():
            custom = self._filename_entry.get().strip()
            if custom:
                return custom
        return fallback

    # ── Fetch ─────────────────────────────────────────────────────────────────
    def _fetch(self):
        url = self.url_entry.get().strip().replace("twitter.com", "x.com")
        if not url: return
        self.url_entry.delete(0, "end"); self.url_entry.insert(0, url)
        self._stop_anim()
        self._gif_data = None; self._gif_frames = []; self._gif_delays = []
        self.fetch_btn.configure(state="disabled", text="Loading…")
        self.save_btn.configure(state="disabled")
        self._img_lbl.config(image="", text="Fetching…")
        self._set_status("Fetching GIF info…"); self._set_progress(0)
        threading.Thread(target=self._do_fetch, args=(url,), daemon=True).start()

    def _do_fetch(self, url):
        try:
            # Download to a temp mp4 first, then convert to GIF with ffmpeg
            import yt_dlp, tempfile, io
            tmp_dir  = Path(tempfile.mkdtemp())
            tmp_mp4  = tmp_dir / "xgif.mp4"
            opts = {
                "quiet": True, "no_warnings": True,
                "outtmpl": str(tmp_mp4),
                "format": "best[ext=mp4]/best",
                "ffmpeg_location": str(_ffmpeg_path),
            }
            # Get info first
            with yt_dlp.YoutubeDL({**opts, "skip_download": True}) as ydl:
                info = ydl.extract_info(url, download=False)
            title    = info.get("title") or info.get("description") or "X GIF"
            uploader = info.get("uploader") or info.get("uploader_id") or "?"
            self.after(0, lambda t=title: self._set_filename_hint(t))
            self.after(0, lambda: self.info_lbl.configure(
                text=f'🎞  "{title[:60]}"  @{uploader}', text_color="#4fc3f7"))
            self.after(0, lambda: self._set_status("Downloading video…"))

            # Download mp4
            with yt_dlp.YoutubeDL(opts) as ydl:
                ydl.download([url])

            # Find the downloaded file
            mp4_files = list(tmp_dir.glob("*.mp4"))
            if not mp4_files: raise RuntimeError("Download produced no mp4 file.")
            mp4_path = mp4_files[0]

            # Convert mp4 → gif using ffmpeg
            self.after(0, lambda: self._set_status("Converting to GIF…"))
            tmp_gif = tmp_dir / "xgif.gif"
            CREATE_NO_WINDOW = 0x08000000
            speed = float(self._speed_var.get().replace("\u00d7", ""))
            setpts = f"setpts={1/speed:.6g}*PTS," if speed != 1.0 else ""
            cmd = [
                str(_ffmpeg_path), "-y",
                "-i", str(mp4_path),
                "-vf", f"{setpts}fps=15,scale=480:-1:flags=lanczos,split[s0][s1];[s0]palettegen[p];[s1][p]paletteuse",
                str(tmp_gif)
            ]
            r = subprocess.run(cmd, capture_output=True, timeout=60,
                               creationflags=CREATE_NO_WINDOW if platform.system()=="Windows" else 0)
            if r.returncode != 0 or not tmp_gif.exists():
                raise RuntimeError("GIF conversion failed.")

            self._gif_data = tmp_gif.read_bytes()
            # Cleanup temp mp4
            try: mp4_path.unlink()
            except Exception: pass

            # Load GIF frames for animation
            from PIL import Image, ImageTk
            import io
            gif_img = Image.open(io.BytesIO(self._gif_data))
            raw_frames = []; delays = []
            try:
                while True:
                    frame = gif_img.copy().convert("RGBA")
                    frame.thumbnail((580, 190))
                    raw_frames.append(frame)
                    delays.append(gif_img.info.get("duration", 80))
                    gif_img.seek(gif_img.tell() + 1)
            except EOFError:
                pass
            self._gif_delays = delays
            self._gif_frames = [ImageTk.PhotoImage(f) for f in raw_frames]
            self.after(0, lambda: (
                self.save_btn.configure(state="normal"),
                self._set_status("Ready to save."),
                self._set_progress(1.0),
                self._start_anim()))
            # Cleanup
            try: tmp_gif.unlink(); tmp_dir.rmdir()
            except Exception: pass
        except Exception as e:
            self.after(0, lambda err=str(e): (
                self.info_lbl.configure(text=f"⚠  {err}", text_color="#ff6b6b"),
                self.fetch_btn.configure(state="normal", text="Grab"),
                self._set_status("Error.")))

    # ── Animation ─────────────────────────────────────────────────────────────
    def _start_anim(self):
        self.fetch_btn.configure(state="normal", text="Grab")
        if not self._gif_frames: return
        self._anim_idx = 0
        self._animate()

    def _animate(self):
        if not self._gif_frames: return
        idx = self._anim_idx % len(self._gif_frames)
        self._img_lbl.config(image=self._gif_frames[idx], text="")
        base_delay = self._gif_delays[idx] if idx < len(self._gif_delays) else 80
        try:
            speed = float(self._speed_var.get().replace("\u00d7", ""))
        except Exception:
            speed = 1.0
        delay = max(20, int(base_delay / speed))
        self._anim_idx += 1
        self._anim_job = self.after(delay, self._animate)

    def _stop_anim(self):
        if self._anim_job:
            try: self.after_cancel(self._anim_job)
            except Exception: pass
            self._anim_job = None

    # ── Save ─────────────────────────────────────────────────────────────────
    def _save(self):
        if not self._gif_data: return
        folder = self.save_var.get().strip()
        if not folder: messagebox.showwarning("No folder", "Choose a save folder first."); return
        push_folder_history("save_folder_gifs", folder)
        import re
        m = re.search(r'"(.+?)"', self.info_lbl.cget("text"))
        fallback = re.sub(r'[\\/:*?"<>|]', "_", m.group(1) if m else "xgif")
        name = re.sub(r'[\\/:*?"<>|]', "_", self._get_save_name(fallback))
        dest = Path(folder) / f"{name}.gif"
        try:
            dest.parent.mkdir(parents=True, exist_ok=True)
            dest.write_bytes(self._gif_data)
            self._log(f"✔  Saved: {dest}"); self._set_status(f"✅  Saved to {dest.name}")
            _notify_done(str(dest.parent), self._open_folder, str(dest))
        except Exception as e:
            messagebox.showerror("Save failed", str(e))


class GifToMp4SubTab(ctk.CTkFrame, _Mixin):
    """Convert a local .gif file to .mp4 using the bundled ffmpeg."""

    def __init__(self, master, **kw):
        super().__init__(master, fg_color="transparent", **kw)
        self._last_file = None
        self._build()

    def _build(self):
