        self._drag_mode  = None   # "move" | "resize"
        self._drag_ox    = 0
        self._drag_oy    = 0
        # display scale + zoom/pan
        self._disp_w     = 1
        self._disp_h     = 1
        self._scale      = 1.0
        self._zoom       = 1.0    # user zoom multiplier (1.0 = fit)
        self._pan_x      = 0.0   # canvas-pixel offset for pan
