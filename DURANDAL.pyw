            cy = 11
            _mc.create_text(cx, cy, text="Download  •  Convert  •  Grab",
                            fill="#888888", font=(self._ui_font_family, 11), anchor="center", tags="bg_text")
            # Measure positions of each word to place a highlight rect under "Convert"
            # We'll use a separate overlay text item for "Convert"
            _mc.create_text(cx, cy, text="Download  •  ", fill="#888888",
                            font=(self._ui_font_family, 11), anchor="e", tags="pre")
            _mc.create_text(cx, cy, text="Convert", fill="#888888",
                            font=(self._ui_font_family, 11), anchor="w", tags="convert_word")
            # Position "  •  Grab" after Convert
            _mc.create_text(cx, cy, text="Convert  •  Grab", fill="#888888",
                            font=(self._ui_font_family, 11), anchor="w", tags="post")
            _mc.delete("bg_text"); _mc.delete("post")
            # Now get bbox of convert_word to position post text
            bb = _mc.bbox("convert_word")
            if bb:
                _mc.create_text(bb[2], cy, text="  •  Grab", fill="#888888",
                                font=(self._ui_font_family, 11), anchor="w", tags="post")
                # Invisible hover rect over Convert word
                _mc.delete("convert_hit")
                _mc.create_rectangle(bb[0]-2, bb[1]-2, bb[2]+2, bb[3]+2,
                                     outline="", fill="", tags="convert_hit")
        _mc.bind("<Configure>", _build_motto)
        self.after(50, _build_motto)
        self.after(60, lambda: _mc.configure(bg=self.cget("bg")) if hasattr(self, "_motto_canvas") else None)

        def _motto_enter(e):
            bb = _mc.bbox("convert_word")
            if bb:
                _mc.delete("convert_hover_bg")
                _mc.create_rectangle(bb[0]-3, bb[1]-2, bb[2]+3, bb[3]+2,
                                     fill="#3a3a4a", outline="", tags="convert_hover_bg")
                _mc.tag_raise("convert_word")
                _mc.tag_raise("convert_hit")
                _mc.itemconfig("convert_word", fill="#e0e0ff")
            _mc.configure(cursor="hand2")
        def _motto_leave(e):
            _mc.delete("convert_hover_bg")
            _mc.itemconfig("convert_word", fill="#888888")
            _mc.configure(cursor="")
        def _motto_click(e):
            self._show_egg()
        _mc.tag_bind("convert_hit", "<Enter>", _motto_enter)
        _mc.tag_bind("convert_hit", "<Leave>", _motto_leave)
        _mc.tag_bind("convert_hit", "<Button-1>", _motto_click)
        _mc.tag_bind("convert_word", "<Enter>", _motto_enter)
        _mc.tag_bind("convert_word", "<Leave>", _motto_leave)
        _mc.tag_bind("convert_word", "<Button-1>", _motto_click)
        self._tm_hue = 0.0

        def _rgb_cycle():
            import math as _math
            t = self._tm_hue
            # Oscillate between deep orange (#c84a00) and bright amber (#ffaa00)
            r = int(180 + 75  * _math.sin(t))
            g = int(90  + 80  * _math.sin(t + _math.pi * 0.4))
            b = 0
            colour = "#{:02x}{:02x}{:02x}".format(
                max(0, min(255, r)),
                max(0, min(255, g)),
                max(0, min(255, b))
            )
            self._tm_canvas.itemconfig(self._tm_text_id, fill=colour)
            self._tm_hue = (self._tm_hue + 0.03) % (2 * _math.pi)
            self._tm_rgb_job = self.after(30, _rgb_cycle)

        self._tm_rgb_job = None
        _rgb_cycle()
        # Sync canvas bg to actual window colour once rendered
        self.after(50, lambda: self._tm_canvas.configure(
            bg=self.cget("bg")) if hasattr(self, "_tm_canvas") else None)

        self._tm_canvas.bind("<Button-1>", lambda e: self._show_credits())

        # ── Update notice bar ──
        self._update_bar = ctk.CTkLabel(
            self._main, text="", text_color="#a8d8a8",
            fg_color="#1e3a1e", corner_radius=6,
            font=ctk.CTkFont(size=11), wraplength=660)

        # ── Tabs ──
        self.tabs = ctk.CTkTabview(self._main, width=680, height=628,
                                   segmented_button_selected_color=YT_RED,
                                   segmented_button_selected_hover_color=YT_HOVER,
                                   command=self._on_tab_change)
        self.tabs.pack(padx=10, pady=(0,10), fill="both", expand=True)
        self.tabs.add("YouTube"); self.tabs.add("Spotify"); self.tabs.add("X"); self.tabs.add("Discord"); self.tabs.add("Art Grab")
        YouTubeTab(self.tabs.tab("YouTube")).pack(fill="both", expand=True)
        # Defer remaining tabs — window appears immediately, others build in next event loop tick
        def _build_deferred_tabs():
            SpotifyTab(self.tabs.tab("Spotify")).pack(fill="both", expand=True)
            XOuterTab(self.tabs.tab("X")).pack(fill="both", expand=True)
            DiscordOuterTab(self.tabs.tab("Discord")).pack(fill="both", expand=True)
            ThumbnailTab(self.tabs.tab("Art Grab")).pack(fill="both", expand=True)
        self.after(0, _build_deferred_tabs)
        # Centre all tab button labels after they're built
        self.after(50, self._centre_tab_labels)

        # ── Settings panel — packs to the right of main, hidden initially ──
        self._settings_panel = SettingsPanel(self)

        # ── Kick off background update check ──
        run_background_updates(on_done=self._show_update_notice)
        check_for_new_release(on_update_found=self._on_new_release_found)

    def _centre_tab_labels(self):
        """Walk the CTkTabview's internal segmented button and centre every label."""
        try:
            seg = self.tabs._segmented_button
            for btn in seg._buttons_dict.values():
                btn.configure(anchor="center")
        except Exception:
            pass

    def _get_bg(self):
        """Return the current window background hex colour for canvas matching."""
        try:
            return self._main.cget("bg")
        except Exception:
            return "#2b2b2b"

    def _toggle_settings(self):
        self._settings_panel.toggle()

    def _on_tab_change(self):
        tab = self.tabs.get()
        if "Spotify" in tab:
            self.tabs.configure(segmented_button_selected_color=ACCENT,
                                segmented_button_selected_hover_color=SP_HOVER)
        elif "𝕏" in tab or "X" in tab:
            self.tabs.configure(segmented_button_selected_color=X_ACCENT,
                                segmented_button_selected_hover_color=X_HOVER)
        elif "Discord" in tab:
            self.tabs.configure(segmented_button_selected_color=DC_ACCENT,
                                segmented_button_selected_hover_color=DC_HOVER)
        elif "Art" in tab:
            self.tabs.configure(segmented_button_selected_color=THUMB_ACCENT,
                                segmented_button_selected_hover_color=THUMB_HOVER)
        else:
            self.tabs.configure(segmented_button_selected_color=YT_RED,
                                segmented_button_selected_hover_color=YT_HOVER)

    def _show_update_notice(self, msg: str):
        self.after(0, self._display_notice, msg)

    def _display_notice(self, msg: str):
        self._update_bar.configure(text=f"  {msg}  ")
        self._update_bar.pack(fill="x", padx=20, pady=(0,6))
        self._update_bar.lift()
        self.after(12_000, self._update_bar.pack_forget)


    def _on_new_release_found(self, latest_version: str, release_url: str):
        """Called from background thread when a newer GitHub release exists."""
        self.after(0, self._show_release_dialog, latest_version, release_url)

    def _show_release_dialog(self, latest_version: str, release_url: str):
        win = ctk.CTkToplevel(self)
        win.title("Update Available")
        win.geometry("380x220")
        win.resizable(False, False)
        win.transient(self)
        win.grab_set()
        self.update_idletasks()
        x = self.winfo_x() + (self.winfo_width()  - 380) // 2
        y = self.winfo_y() + (self.winfo_height() - 220) // 2
        win.geometry(f"+{x}+{y}")

        ctk.CTkLabel(win, text="🆕  Update Available",
                     font=ctk.CTkFont(size=16, weight="bold")).pack(pady=(22, 4))
        ctk.CTkLabel(win,
                     text=f"DURANDAL {latest_version} is out.\nYou're on v{VERSION}.",
                     text_color="gray70", font=ctk.CTkFont(size=12),
                     justify="center").pack(pady=(0, 18))

        btn_row = ctk.CTkFrame(win, fg_color="transparent")
