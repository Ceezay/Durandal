        ctk.CTkEntry(sr, textvariable=self.save_var, width=315).pack(side="left", padx=6)
        ctk.CTkButton(sr, text="Browse…", width=80,
                      fg_color=G2M_ACCENT, hover_color=G2M_HOVER,
                      command=lambda: self._browse(self.save_var)).pack(side="left")
        self._g2m_hist_btn = ctk.CTkButton(sr, text="▾", width=28, height=28,
                      fg_color="transparent", border_width=1,
                      command=lambda: self._show_folder_history("save_folder_gif2mp4", self.save_var, self._g2m_hist_btn))
        self._g2m_hist_btn.pack(side="left", padx=(4,0))

        # Filename row
        fn_frame = ctk.CTkFrame(self, fg_color="transparent"); fn_frame.pack(fill="x", padx=18, pady=(0,4))
        self._custom_name_var = ctk.BooleanVar(value=False)
        ctk.CTkCheckBox(fn_frame, text="Custom filename:", variable=self._custom_name_var,
                         fg_color=G2M_ACCENT, hover_color=G2M_HOVER, checkmark_color="white",
                         command=self._toggle_filename).pack(side="left")
        self._filename_entry = ctk.CTkEntry(fn_frame, width=268, text_color="gray50",
                                             state="disabled")
        self._filename_entry.pack(side="left", padx=(8,0))
        self._fn_clear_btn = ctk.CTkButton(fn_frame, text="✕", width=28, height=28,
                                            fg_color="#cc2222", hover_color="#aa1a1a",
                                            text_color="white", state="disabled",
                                            command=self._clear_filename)
        self._fn_clear_btn.pack(side="left", padx=(4,0))

        # Convert button
        self.dl_btn = ctk.CTkButton(self, text="🔄  Convert to MP4", height=40,
                                     font=ctk.CTkFont(size=14, weight="bold"),
                                     fg_color=G2M_ACCENT, hover_color=G2M_HOVER,
                                     state="disabled",
                                     command=self._start)
        self.dl_btn.pack(pady=10)

        # Progress + log
        self.progress_bar = ctk.CTkProgressBar(self, width=620, progress_color=G2M_ACCENT)
        self.progress_bar.set(0); self.progress_bar.pack()
        self.status_lbl = ctk.CTkLabel(self, text="Ready.", text_color="gray60", wraplength=620)
        self.status_lbl.pack(pady=3)
        self.log_box = ctk.CTkTextbox(self, width=620, state="disabled",
                                       font=ctk.CTkFont(family="Courier", size=10))
        self.log_box.pack(padx=18, pady=(0,8), fill="both", expand=True)

    def _browse_gif(self):
        from tkinter import filedialog as _fd
        path = _fd.askopenfilename(
            title="Select a GIF file",
            filetypes=[("GIF files", "*.gif"), ("All files", "*.*")]
        )
        if not path: return
        self._gif_path_var.set(path)
        # Pre-fill filename entry with the GIF stem
        stem = Path(path).stem
        self._set_filename_hint(stem)
        # Show file info
        try:
            size_mb = Path(path).stat().st_size / 1_048_576
            self.info_lbl.configure(
                text=f"📂  {Path(path).name}  |  {size_mb:.1f} MB",
                text_color="#4fc3f7")
        except Exception:
            pass

    def _toggle_filename(self):
        active = self._custom_name_var.get()
        self._filename_entry.configure(
            state="normal" if active else "disabled",
            text_color="white" if active else "gray50")
        self._fn_clear_btn.configure(state="normal" if active else "disabled")
        if active:
            self._filename_entry.focus_set()
        else:
            # Unticked — restore the original hint if the entry was left empty
            hint = getattr(self, "_last_filename_hint", "")
            if hint and not self._filename_entry.get().strip():
                self._filename_entry.configure(state="normal")
                self._filename_entry.delete(0, "end")
                self._filename_entry.insert(0, hint)
                self._filename_entry.configure(state="disabled", text_color="gray50")

    def _clear_filename(self):
        self._filename_entry.delete(0, "end")
        self._filename_entry.focus_set()

    def _get_save_name(self, fallback):
        if self._custom_name_var.get():
            custom = self._filename_entry.get().strip()
            if custom: return custom
        return fallback

    def _start(self):
        gif_path = self._gif_path_var.get().strip()
        save     = self.save_var.get().strip()
        if not gif_path:
            messagebox.showwarning("No file", "Please select a GIF file first."); return
        if not Path(gif_path).exists():
            messagebox.showwarning("File not found", f"Cannot find:\n{gif_path}"); return
        if not save:
            messagebox.showwarning("No folder", "Please choose a save folder."); return
        push_folder_history("save_folder_gif2mp4", save)
        self.dl_btn.configure(state="disabled", text="Converting…")
        self._set_status("Converting…"); self._set_progress(0)
        threading.Thread(target=self._do_convert, args=(gif_path, save), daemon=True).start()

    def _do_convert(self, gif_path, save):
        try:
            stem     = Path(gif_path).stem
            out_name = self._get_save_name(stem)
            out_path = Path(save) / f"{out_name}.mp4"
            out_path.parent.mkdir(parents=True, exist_ok=True)

            # Build ffmpeg filter
            scale = self.scale_var.get()
            fps   = self.fps_var.get()
            vf_parts = []
            if scale != "Original size":
                h = scale.replace("p","")
                vf_parts.append(f"scale=-2:{h}")
            if fps != "Match GIF":
                vf_parts.append(f"fps={fps}")
            # Pad to even dimensions (required for libx264)
            vf_parts.append("pad=ceil(iw/2)*2:ceil(ih/2)*2")
            vf = ",".join(vf_parts) if vf_parts else "pad=ceil(iw/2)*2:ceil(ih/2)*2"

            CREATE_NO_WINDOW = 0x08000000
            cmd = [
                str(_ffmpeg_path), "-y",
                "-i", gif_path,
                "-vf", vf,
                "-c:v", "libx264",
                "-pix_fmt", "yuv420p",
                "-movflags", "+faststart",
                str(out_path)
            ]
            self.after(0, lambda: self._set_status("Running ffmpeg…"))
            r = subprocess.run(cmd, capture_output=True, timeout=300,
                               creationflags=CREATE_NO_WINDOW if platform.system()=="Windows" else 0)

            if r.returncode != 0:
                err = r.stderr.decode(errors="ignore").splitlines()
                msg = next((l for l in reversed(err) if l.strip()), "ffmpeg failed")
                raise RuntimeError(msg)

            self._last_file = str(out_path)
            size_mb = out_path.stat().st_size / 1_048_576
            self.after(0, lambda: (
                self.dl_btn.configure(state="normal", text="🔄  Convert to MP4"),
                self._set_progress(1.0),
                self._set_status(f"✅  Done — {out_path.name}  ({size_mb:.1f} MB)"),
                self._log(f"✔  Saved: {out_path}"),
                _notify_done(save, self._open_folder, self._last_file)
            ))
        except Exception as e:
            self.after(0, lambda err=str(e): (
                self.dl_btn.configure(state="normal", text="🔄  Convert to MP4"),
                self._set_status("❌  Error — see log"),
                self._log(f"ERROR: {err}"),
                messagebox.showerror("Conversion failed", err)
            ))


