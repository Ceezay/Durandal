class DiscordDownloaderSubTab(ctk.CTkFrame, _Mixin):
    """Download any CDN attachment from a Discord link — auto-detects type."""

    # MIME → category mapping (subset; remainder fall back to generic)
    _TYPE_MAP = {
        # images
        "image/png": "image", "image/jpeg": "image", "image/webp": "image",
        "image/gif": "gif",   "image/apng": "gif",
        # video
        "video/mp4": "video", "video/webm": "video", "video/quicktime": "video",
        "video/x-matroska": "video",
        # audio
        "audio/ogg": "audio", "audio/mpeg": "audio", "audio/mp4": "audio",
        "audio/wav": "audio", "audio/webm": "audio", "audio/flac": "audio",
        "audio/aac": "audio",
    }

    _ICONS = {
        "image": "🖼",
        "gif":   "🎞",
        "video": "🎬",
        "audio": "🎵",
        "other": "📄",
    }

    def __init__(self, master, **kw):
