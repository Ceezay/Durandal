    def _browse_folder(self, var, pref_key):
        from tkinter import filedialog as _fd
        p = _fd.askdirectory(title="Choose save folder", initialdir=var.get())
        if p:
            var.set(p)
            set_pref(pref_key, p)

    def _toggle_filename(self):
        active = self._custom_name_var.get()
        self._filename_entry.configure(
            state="normal"  if active else "disabled",
            text_color="white" if active else "gray50")
        self._fn_clear_btn.configure(state="normal" if active else "disabled")
        if active:
            self._filename_entry.focus_set()
        else:
            hint = getattr(self, "_last_filename_hint", "")
            if hint and not self._filename_entry.get().strip():
                self._filename_entry.configure(state="normal")
                self._filename_entry.delete(0, "end")
                self._filename_entry.insert(0, hint)
                self._filename_entry.configure(state="disabled", text_color="gray50")

    def _clear_filename(self):
        self._filename_entry.delete(0, "end")
        self._filename_entry.focus_set()

    def _trim_toggle(self):
        if self.trim_var.get():
            self.trim_body.pack(fill="x")
        else:
            self.trim_body.pack_forget()

    def _on_start_slider(self, val):
        if not getattr(self, "_duration", None):
            return
        secs = val / 100 * self._duration
        end_secs = _to_sec(self.trim_end.get()) or self._duration
        secs = min(secs, end_secs - 1)
        self.trim_start.delete(0, "end")
        self.trim_start.insert(0, _fmt_sec(secs))
        self._trim_preview()

    def _on_end_slider(self, val):
        if not getattr(self, "_duration", None):
            return
        secs = val / 100 * self._duration
        start_secs = _to_sec(self.trim_start.get()) or 0
        secs = max(secs, start_secs + 1)
        self.trim_end.delete(0, "end")
        self.trim_end.insert(0, _fmt_sec(secs))
        self._trim_preview()

    def _on_start_entry(self):
        s = _to_sec(self.trim_start.get())
        if s is not None and getattr(self, "_duration", None):
            self.trim_start_slider.set(min(s / self._duration * 100, 99))
        self._trim_preview()

    def _on_end_entry(self):
        e = _to_sec(self.trim_end.get())
        if e is not None and getattr(self, "_duration", None):
            self.trim_end_slider.set(min(e / self._duration * 100, 100))
        self._trim_preview()

    def _trim_preview(self):
        s, e = _to_sec(self.trim_start.get()), _to_sec(self.trim_end.get())
        if s is not None and e is not None and e > s:
            self.trim_prev.configure(text=f"Clip: {_fmt_sec(e-s)}", text_color="#4fc3f7")
        else:
            self.trim_prev.configure(text="")

    def _fetch(self):
        url = self.url_entry.get().strip()
        if not url:
            self.info_lbl.configure(text="⚠  Paste an X/Twitter URL first.", text_color="#ff6b6b")
            return
        url = url.replace("twitter.com", "x.com")
        self.url_entry.delete(0, "end"); self.url_entry.insert(0, url)
        self.fetch_btn.configure(state="disabled", text="Loading…")
        self.dl_btn.configure(state="disabled")
        self.info_lbl.configure(text="Fetching info…", text_color="gray55")
        import threading
        threading.Thread(target=self._do_fetch, args=(url,), daemon=True).start()

    def _do_fetch(self, url):
        import yt_dlp
        try:
            with yt_dlp.YoutubeDL({"quiet": True, "no_warnings": True,
                                    "skip_download": True,
                                    "ffmpeg_location": str(_ffmpeg_path)}) as ydl:
                info = ydl.extract_info(url, download=False)
            title    = info.get("title") or info.get("description") or "X Video"
            uploader = info.get("uploader") or "?"
            dur      = info.get("duration")
            duration = float(dur) if dur else None
            dur_s    = _fmt_sec(duration) if duration else "?"

            def _update():
                self._duration = duration
                self.info_lbl.configure(
                    text=f'🐦  "{title[:60]}"  @{uploader}  |  {dur_s}',
                    text_color="#4fc3f7")
                self.fetch_btn.configure(state="normal", text="Load Info")
                self.dl_btn.configure(state="normal")
                self._set_filename_hint(title)
                if duration:
                    self.trim_dur_lbl.configure(text=f"Duration: {dur_s}")
                    self.trim_start_slider.set(0)
                    self.trim_end_slider.set(100)
                    self.trim_start.delete(0, "end")
                    self.trim_end.delete(0, "end")
                    self.trim_end.insert(0, _fmt_sec(duration))
                else:
                    self.trim_dur_lbl.configure(text="")

            self.after(0, _update)
        except Exception as e:
            err = str(e).splitlines()[-1][:140]
            self.after(0, lambda: (
                self.info_lbl.configure(text=f"⚠  {err}", text_color="#ff6b6b"),
                self.fetch_btn.configure(state="normal", text="Load Info"),
                self.dl_btn.configure(state="disabled")
            ))

    def _start(self):
        url  = self.url_entry.get().strip()
        save = self.save_var.get().strip()
        if not url:  messagebox.showwarning("No URL", "Paste an X/Twitter URL first."); return
        if not save: messagebox.showwarning("No folder", "Choose a save folder."); return
        ts = te = None
        if self.trim_var.get():
            ts, te = _to_sec(self.trim_start.get()), _to_sec(self.trim_end.get())
            if ts is None or te is None:
                messagebox.showwarning("Bad trim", "Enter valid times (HH:MM:SS or MM:SS)."); return
            if te <= ts:
                messagebox.showwarning("Bad trim", "End must be after start."); return
        if not self._confirm_download("X → GIF"): return
        self._maybe_clear_log()
        self.dl_btn.configure(state="disabled", text="Converting…")
        self.progress_bar.set(0)
        import threading
        threading.Thread(target=self._worker, args=(url, save, ts, te), daemon=True).start()

    def _worker(self, url, save, ts, te):
        import yt_dlp, tempfile, subprocess, os
        try:
            fps   = self._fps_var.get()
            width = self._width_var.get()
            cols  = self._col_var.get()
            speed = float(self._speed_var.get().replace("\u00d7", ""))
            fname = (self._filename_entry.get().strip() or "x_gif") + ".gif"
            out   = Path(save) / fname

            self.after(0, lambda: self._log("⬇  Downloading video…"))
            self.after(0, lambda: self.progress_bar.set(0.2))

            with tempfile.TemporaryDirectory() as tmp:
                tmp_mp4 = str(Path(tmp) / "video.mp4")
                ydl_opts = {
                    "quiet": True, "no_warnings": True,
                    "outtmpl": tmp_mp4,
                    "format": "bestvideo[ext=mp4]+bestaudio/best[ext=mp4]/best",
                    "ffmpeg_location": str(_ffmpeg_path),
                }
                with yt_dlp.YoutubeDL(ydl_opts) as ydl:
                    ydl.download([url])

                self.after(0, lambda: self._log("🔄  Converting to GIF…"))
                self.after(0, lambda: self.progress_bar.set(0.6))

                # Locate the actual downloaded file (yt-dlp may add .mp4 or merge ext)
                actual_mp4 = tmp_mp4
                for f in Path(tmp).iterdir():
                    if f.suffix in (".mp4", ".mkv", ".webm"):
                        actual_mp4 = str(f)
                        break

                # Build trim args if requested (-ss/-to placed before -i for fast seek)
                trim_in  = ["-ss", str(ts)] if ts is not None else []
                trim_out = ["-to", str(te)] if te is not None else []

                # Build palette then convert
                palette = str(Path(tmp) / "palette.png")
                setpts  = f"setpts={1/speed:.6g}*PTS," if speed != 1.0 else ""
                vf_base = f"{setpts}fps={fps},scale={width}:-1:flags=lanczos"
                cmd_pal = (
                    [str(_ffmpeg_path), "-y"]
                    + trim_in + trim_out
                    + ["-i", actual_mp4,
                       "-vf", f"{vf_base},palettegen=max_colors={cols}",
                       palette]
                )
                cmd_gif = (
                    [str(_ffmpeg_path), "-y"]
                    + trim_in + trim_out
                    + ["-i", actual_mp4, "-i", palette,
                       "-lavfi", f"{vf_base}[x];[x][1:v]paletteuse",
                       str(out)]
                )
                for cmd in (cmd_pal, cmd_gif):
                    r = subprocess.run(cmd, capture_output=True,
                                       creationflags=0x08000000 if platform.system()=="Windows" else 0)
                    if r.returncode != 0:
                        raise RuntimeError(r.stderr.decode(errors="ignore").splitlines()[-1])

            self._last_file = str(out)
            size_mb = out.stat().st_size / 1_048_576
            self.after(0, lambda: (
                self.dl_btn.configure(state="normal", text="🔄  Convert to GIF"),
                self.progress_bar.set(1.0),
                self.status_lbl.configure(text=f"✅  Done — {out.name}  ({size_mb:.1f} MB)"),
                self._log(f"✔  Saved: {out}"),
                _notify_done(save, self._open_folder, self._last_file)
            ))
        except Exception as e:
            self.after(0, lambda err=str(e): (
                self.dl_btn.configure(state="normal", text="🔄  Convert to GIF"),
                self.status_lbl.configure(text="❌  Error — see log"),
                self._log(f"ERROR: {err}"),
                messagebox.showerror("Conversion failed", err)
            ))

    def _open_folder(self, path):
        _open_and_highlight(path)


