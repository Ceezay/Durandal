    def _toggle_filename(self):
        active = self._custom_name_var.get()
        self._filename_entry.configure(
            state="normal"  if active else "disabled",
            text_color="white" if active else "gray50")
        self._fn_clear_btn.configure(state="normal" if active else "disabled")
        if active:
            self._filename_entry.focus_set()
        else:
            # Unticked — restore the original hint if the entry was left empty
            hint = getattr(self, "_last_filename_hint", "")
            if hint and not self._filename_entry.get().strip():
                self._filename_entry.configure(state="normal")
                self._filename_entry.delete(0, "end")
                self._filename_entry.insert(0, hint)
                self._filename_entry.configure(state="disabled", text_color="gray50")

    def _clear_filename(self):
        self._filename_entry.delete(0, "end")
        self._filename_entry.focus_set()

    def _get_save_name(self, fallback):
        """Return the filename stem to use, custom or derived."""
        if self._custom_name_var.get():
            custom = self._filename_entry.get().strip()
            if custom:
                return custom
        return fallback

    def _source(self, url):
        if "spotify.com" in url:
            return "spotify"
        return "youtube"

    def _is_unsupported(self, url):
        return any(d in url for d in ("x.com", "twitter.com", "t.co"))

    def _fetch(self):
        url = self.url_entry.get().strip()
        if not url: return
        if self._is_unsupported(url):
            self.info_lbl.configure(
                text="⚠  X/Twitter links aren't supported here — use the 𝕏 X tab to download videos or the 🎞 GIF tab for GIFs.",
                text_color="#ff6b6b")
            return
        self.fetch_btn.configure(state="disabled", text="Loading…")
        self.save_btn.configure(state="disabled")
        self._thumb_url = self._thumb_data = None
        self._img_lbl.config(image="", text="Fetching…")
        self._set_status("Fetching info…"); self._set_progress(0)
        threading.Thread(target=self._do_fetch, args=(url,), daemon=True).start()

    def _do_fetch(self, url):
        try:
            if self._source(url) == "youtube":
                self._fetch_youtube(url)
            else:
                self._fetch_spotify(url)
        except Exception as e:
            self.after(0, lambda err=str(e): (
                self.info_lbl.configure(text=f"⚠  {err}", text_color="#ff6b6b"),
                self.fetch_btn.configure(state="normal", text="Grab"),
                self._set_status("Error.")))

    def _fetch_youtube(self, url):
        import yt_dlp
        opts = {"quiet": True, "no_warnings": True, "skip_download": True, "noplaylist": True}
        with yt_dlp.YoutubeDL(opts) as ydl:
            info = ydl.extract_info(url, download=False)
        title = info.get("title", "Unknown"); uploader = info.get("uploader", "?")
        thumbs = sorted([t for t in (info.get("thumbnails") or []) if t.get("url")],
                        key=lambda t: (t.get("width") or 0)*(t.get("height") or 0), reverse=True)
        if not thumbs: raise RuntimeError("No thumbnails found.")
        q = self.quality_var.get()
        if   q == "Max (original)": thumb = thumbs[0]
        elif q == "High (1280px)":  thumb = next((t for t in thumbs if (t.get("width") or 9999)<=1280), thumbs[0])
        elif q == "Medium (640px)": thumb = next((t for t in thumbs if (t.get("width") or 9999)<=640),  thumbs[0])
        else:                        thumb = thumbs[-1]
        self._thumb_url = thumb["url"]
        w = thumb.get("width","?"); h = thumb.get("height","?")
        self.after(0, lambda t=title: self._set_filename_hint(t))
        self.after(0, lambda: (
            self.info_lbl.configure(text=f'🎬  "{title}"  by {uploader}  |  {w}×{h}', text_color="#4fc3f7"),
            self.fetch_btn.configure(state="normal", text="Grab")))
        self._load_preview(self._thumb_url)

    def _fetch_spotify(self, url):
        import urllib.request as _ur, json as _json
        with _ur.urlopen(f"https://open.spotify.com/oembed?url={url}", timeout=10) as resp:
            data = _json.loads(resp.read())
        self._thumb_url = data.get("thumbnail_url")
        if not self._thumb_url: raise RuntimeError("No artwork found.")
        title = data.get("title", "Unknown")
        self.after(0, lambda t=title: self._set_filename_hint(t))
        self.after(0, lambda: (
            self.info_lbl.configure(text=f'🎵  "{title}"', text_color="#4fc3f7"),
            self.fetch_btn.configure(state="normal", text="Grab")))
        self._load_preview(self._thumb_url)

    def _load_preview(self, img_url):
        self.after(0, lambda: self._img_lbl.config(image="", text="Loading preview…"))
        threading.Thread(target=self._do_preview, args=(img_url,), daemon=True).start()

    def _do_preview(self, img_url):
        try:
            import urllib.request as _ur, io
            from PIL import Image, ImageTk
            with _ur.urlopen(img_url, timeout=15) as resp:
                self._thumb_data = resp.read()
            img = Image.open(io.BytesIO(self._thumb_data)); img.thumbnail((600, 195))
            photo = ImageTk.PhotoImage(img); self._current_photo = photo
            self.after(0, lambda: (
                self._img_lbl.config(image=self._current_photo, text=""),
                self.save_btn.configure(state="normal"),
                self._set_status("Ready to save."), self._set_progress(1.0)))
        except Exception as e:
            self.after(0, lambda err=str(e): (
                self._img_lbl.config(image="", text=f"⚠  Preview failed: {err}"),
                self._set_status("Preview error.")))

    def _save(self):
        if not self._thumb_data: return
        folder = self.save_var.get().strip()
        if not folder: messagebox.showwarning("No folder", "Choose a save folder first."); return
        push_folder_history("save_folder_thumbs", folder)
        import re
        m = re.search(r'"(.+?)"', self.info_lbl.cget("text"))
        fallback = re.sub(r'[\\/:*?"<>|]', "_", m.group(1) if m else "thumbnail")
        name = re.sub(r'[\\/:*?"<>|]', "_", self._get_save_name(fallback))
        ext = ".jpg"
        if self._thumb_url:
            from urllib.parse import urlparse
            p = Path(urlparse(self._thumb_url).path)
            if p.suffix.lower() in (".jpg",".jpeg",".png",".webp"): ext = p.suffix.lower()
        dest = Path(folder) / f"{name}{ext}"
        try:
            dest.parent.mkdir(parents=True, exist_ok=True)
            dest.write_bytes(self._thumb_data)
            self._log(f"✔  Saved: {dest}"); self._set_status(f"✅  Saved to {dest.name}")
            _notify_done(str(dest.parent), self._open_folder, str(dest))
        except Exception as e:
            messagebox.showerror("Save failed", str(e))


