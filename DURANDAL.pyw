    def _on_scale_slide(self, val):
        """Update the percentage label as the slider moves."""
        pct = int(round(float(val) * 100))
        self._scale_val_lbl.configure(text=f"{pct}%")

    def _apply_scale(self):
        """Apply the selected scale and persist it."""
        val = round(self._scale_var.get(), 2)
        set_pref("ui_scale", val)
        ctk.set_widget_scaling(val)
        ctk.set_window_scaling(val)
        self._scale_status.configure(text="✅  Applied")
        self.after(2500, lambda: self._scale_status.configure(text=""))

    # ── Instant snap open/close ───────────────────────────────────────────────
    def toggle(self):
        if self._visible: self.hide()
        else:             self.show()

    def show(self):
        if self._visible: return
        self._visible = True
        self._refresh_folders()
        self.master.geometry(f"{self.BASE_W + self.PANEL_W}x{self.WIN_H}")
        self.master.update_idletasks()
        self.pack(side="left", fill="y")

    def _refresh_folders(self):
        """Sync all folder StringVars to the latest saved prefs."""
        _map = {
            "_yt_folder_var":  "save_folder_youtube",
            "_sp_folder_var":  "save_folder_spotify",
            "_x_folder_var":   "save_folder_x",
            "_th_folder_var":  "save_folder_thumbs",
            "_gif_folder_var": "save_folder_gifs",
            "_g2m_folder_var": "save_folder_gif2mp4",
            "_dc_folder_var":  "save_folder_discord",
        }
        for attr, pref_key in _map.items():
            var = getattr(self, attr, None)
            if var:
                var.set(get_pref(pref_key))

    def hide(self):
        if not self._visible: return
        self._visible = False
        self.master.geometry(f"{self.BASE_W + self.PANEL_W}x{self.WIN_H}")
        self.pack_forget()
        self.master.update_idletasks()
        self.master.geometry(f"{self.BASE_W}x{self.WIN_H}")

    def _change_folder(self, pref_key, var, status_lbl):
        folder = filedialog.askdirectory(
            title="Choose save folder",
            initialdir=var.get())
        if folder:
            var.set(folder)
            set_pref(pref_key, folder)
            status_lbl.configure(text="✅  Saved")
            self.after(2500, lambda s=status_lbl: s.configure(text=""))

    def _get_version(self, name):
        """Return version string for a component."""
        if name == "Python":
            return sys.version.split()[0]
        elif name == "FFmpeg":
            try:
                r = subprocess.run([str(_ffmpeg_path), "-version"],
                                   capture_output=True, text=True, timeout=5)
                raw = r.stdout.splitlines()[0].split("version")[-1].strip().split()[0]
                return raw.split("-")[0].split("_")[0]
            except Exception:
                return "not found"
        else:
            return _get_installed_version(name) or "not installed"

    def _refresh_versions(self, statuses=None, ver_overrides=None):
        """
        Update each component row.
        statuses:      dict of name -> ok | updated | checking | error
        ver_overrides: dict of name -> display string (e.g. "2025.1 → 2026.3")
        """
        COMPONENTS = ["yt-dlp", "spotdl", "customtkinter", "Pillow", "mutagen", "Python", "FFmpeg"]
        statuses     = statuses     or {}
        ver_overrides = ver_overrides or {}
        for name in COMPONENTS:
            if name not in self._comp_rows:
                continue
            row    = self._comp_rows[name]
            ver    = ver_overrides.get(name) or self._get_version(name)
            status = statuses.get(name)

            row["ver"].configure(text=ver)

            if status == "checking":
                row["icon"].configure(text="⏳", text_color="#4fc3f7")
                row["ver"].configure(text_color="gray60")
                row["bar"].pack(side="right", padx=(4,0))
                row["bar"].configure(mode="indeterminate")
                row["bar"].start()
            elif status == "updated":
                row["bar"].stop(); row["bar"].pack_forget()
                row["icon"].configure(text="🆕", text_color="#4fc3f7")
                row["ver"].configure(text_color="#4fc3f7")
            elif status == "ok":
                row["bar"].stop(); row["bar"].pack_forget()
                row["icon"].configure(text="✅", text_color="#a8d8a8")
                row["ver"].configure(text_color="#a8d8a8")
            elif status == "error":
                row["bar"].stop(); row["bar"].pack_forget()
                row["icon"].configure(text="❌", text_color="#ff6b6b")
                row["ver"].configure(text_color="#ff6b6b")
            else:
                row["bar"].stop(); row["bar"].pack_forget()
                row["icon"].configure(text="⬜", text_color="gray60")
                row["ver"].configure(text_color="gray60")

    def _check_updates_now(self):
        self._upd_btn.configure(state="disabled", text="Checking…")
        self._upd_overall.configure(text="Checking all components…", text_color="#4fc3f7")
        try: UPDATE_STAMP.unlink()
        except FileNotFoundError: pass

        UPGRADEABLE = ["yt-dlp", "spotdl", "customtkinter", "Pillow", "mutagen"]
        STATIC      = ["Python", "FFmpeg"]

        # Show all upgradeable as checking, static as ok immediately
        init = {n: "checking" for n in UPGRADEABLE}
        init.update({n: "ok" for n in STATIC})

        # Capture refs before entering thread — avoids closure issues
        refresh_fn  = self._refresh_versions
        overall_lbl = self._upd_overall
        btn         = self._upd_btn
        root        = self.master   # App window — its after() is always reliable

        def _ui(fn, *args, **kwargs):
            """Schedule a UI call on the root window's event loop."""
            root.after(0, lambda: fn(*args, **kwargs))

        def _worker():
            _record_check()
            _ui(refresh_fn, init, {})   # show "checking" spinners

            final        = {n: "ok" for n in STATIC}
            ver_display  = {}           # name -> what to show in the ver column
            updated_list = []           # human-readable update log

            for pkg in UPGRADEABLE:
                # Grab version BEFORE attempting upgrade
                before = _get_installed_version(pkg) or "?"
                try:
                    old_v, new_v = _pip_upgrade(pkg)
                    if new_v:
                        final[pkg]       = "updated"
                        ver_display[pkg] = f"{old_v}  →  {new_v}"
                        updated_list.append(f"{pkg} ({old_v} → {new_v})")
                    else:
                        final[pkg]       = "ok"
                        ver_display[pkg] = f"{before}  ✓ latest"
                except Exception as e:
                    final[pkg]       = "error"
                    ver_display[pkg] = f"{before}  (failed)"
                # Update this row immediately so user sees progress
                _ui(refresh_fn, dict(final), dict(ver_display))

            if updated_list:
                msg = "🆕  Updated " + str(len(updated_list)) + " package(s):  " + ",  ".join(updated_list)
                col = "#4fc3f7"
            else:
                msg = "✅  All packages are already on the latest version."
                col = "#a8d8a8"

            _ui(overall_lbl.configure, text=msg, text_color=col)
            _ui(btn.configure, state="normal", text="Check & Update All")

        threading.Thread(target=_worker, daemon=True).start()



