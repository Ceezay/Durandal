    def _show_egg(self):
        import base64 as _b64, io as _io
        import tkinter as _tk
        from PIL import Image, ImageTk
        win = ctk.CTkToplevel(self)
        win.title("Homer Conversion")
        win.resizable(False, False)
        win.transient(self)
        win.grab_set()
        win.configure(fg_color="black")
        try:
            _raw = _b64.b64decode(_EGG_B64)
            _pil_orig = Image.open(_io.BytesIO(_raw))
            img_w, img_h = _pil_orig.size

            # Target content size (no chrome yet)
            max_w = 700
            if img_w > max_w:
                img_h = int(img_h * max_w / img_w)
                img_w = max_w

            # Position window centred on parent
            self.update_idletasks()
            px = self.winfo_x() + (self.winfo_width()  - img_w) // 2
            py = self.winfo_y() + (self.winfo_height() - img_h) // 2
            win.geometry(f"{img_w}x{img_h}+{px}+{py}")
            win.update_idletasks()

            # After the window is realised, measure actual inner client area
            # and resize image to fill it exactly
            def _fill(orig=_pil_orig, iw=img_w, ih=img_h):
                try:
                    cw = win.winfo_width()
                    ch = win.winfo_height()
                    if cw < 10 or ch < 10:
                        cw, ch = iw, ih
                    _pil2  = orig.resize((cw, ch), Image.LANCZOS)
                    _photo = ImageTk.PhotoImage(_pil2)
                    lbl.configure(image=_photo)
                    lbl.image = _photo
                    lbl.configure(bg="black")
                except Exception:
                    pass

            lbl = _tk.Label(win, bd=0, highlightthickness=0, bg="black")
            lbl.pack(fill="both", expand=True)
            lbl.bind("<Button-1>", lambda e: win.destroy())
            win.bind("<Button-1>",  lambda e: win.destroy())
            win.after(50, _fill)
        except Exception:
            win.destroy()

    def _open_link(self, url: str):
        import webbrowser
        webbrowser.open(url)


