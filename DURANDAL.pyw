class _Mixin:
    def _log(self, msg):
        self.log_box.configure(state="normal")
        self.log_box.insert("end", msg+"\n")
        self.log_box.see("end")
        self.log_box.configure(state="disabled")

    def _clear_log(self):
        self.log_box.configure(state="normal")
        self.log_box.delete("1.0", "end")
        self.log_box.configure(state="disabled")

    def _confirm_download(self, label="Download") -> bool:
        """Return True if the user confirms, or if confirm pref is off."""
        if not get_pref("confirm_before_download"):
            return True
        return messagebox.askyesno("Confirm", f"Start {label}?")

    def _maybe_clear_log(self):
        """Clear log before starting if pref is set."""
        if get_pref("clear_log_on_start"):
            self._clear_log()

    def _set_status(self, msg): self.status_lbl.configure(text=msg)
    def _set_progress(self, v): self.progress_bar.set(min(max(v,0.0),1.0))

    def _browse(self, var):
        d = filedialog.askdirectory(title="Choose save folder", initialdir=var.get())
        if d: var.set(d)

    def _open_folder(self, path):
        _open_and_highlight(path)

    def _set_filename_hint(self, title: str):
        """Populate the filename entry with the sanitised title (always, ticked or not)."""
        import re as _re
        safe = _re.sub(r'[\/:*?"<>|]', "_", title).strip()
        self._last_filename_hint = safe          # remember for restore-on-untick
        try:
            active = self._custom_name_var.get()
            if not active:
                self._filename_entry.configure(state="normal")
            self._filename_entry.delete(0, "end")
            self._filename_entry.insert(0, safe)
            if not active:
                self._filename_entry.configure(state="disabled", text_color="gray50")
        except Exception:
            pass

    def _show_folder_history(self, pref_key: str, save_var: ctk.StringVar, btn_widget):
        """Pop up a menu of recent save paths under the history button."""
        history = get_folder_history(pref_key)
        if not history:
            return
        import tkinter as _tk
        menu = _tk.Menu(self, tearoff=0)
        for path in history:
            menu.add_command(
                label=path,
                command=lambda p=path: save_var.set(p)
            )
        try:
            x = btn_widget.winfo_rootx()
            y = btn_widget.winfo_rooty() + btn_widget.winfo_height()
            menu.tk_popup(x, y)
        finally:
            menu.grab_release()

    def _progress_hook(self, d):
        if d["status"]=="downloading":
            raw = re.sub(r"\x1b\[[0-9;]*m","",d.get("_percent_str","0%")).replace("%","").strip()
            try:    pct=float(raw)/100
            except: pct=0.0
            dl  = d.get("_downloaded_bytes_str","?")
            tot = d.get("_total_bytes_str") or d.get("_total_bytes_estimate_str","?")
            spd = d.get("_speed_str","?")
            eta = d.get("_eta_str","?")
            fn  = os.path.basename(d.get("filename",""))
            self.after(0, self._set_status, f"📥  {fn[:48]}  {dl}/{tot}  {spd}  ETA {eta}")
            self.after(0, self._set_progress, pct)
        elif d["status"]=="finished":
            fname = d.get("filename","")
            self._last_file = fname
            self.after(0, self._log, f"✔  {os.path.basename(fname)}")
            self.after(0, self._set_progress, 1.0)

# ─────────────────────────────────────────────────────────────────────────────
#  YouTube Tab
# ─────────────────────────────────────────────────────────────────────────────
class YouTubeTab(ctk.CTkFrame, _Mixin):
    QUALITIES = ["Best available","4K (2160p)","1440p","1080p","720p","480p"]
    FPS_OPTS  = ["Any FPS","60 FPS","30 FPS"]
    BITRATES  = ["320k","256k","192k","128k","96k"]

    def __init__(self, master, **kw):
        super().__init__(master, fg_color="transparent", **kw)
        self._duration  = None
        self._video_url = None
        self._build()

    def _build(self):
        P = dict(padx=18, pady=5)

        # URL row
        ctk.CTkLabel(self, text="YouTube URL  (video, Shorts or playlist):", anchor="w").pack(fill="x", **P)
        r = ctk.CTkFrame(self, fg_color="transparent"); r.pack(fill="x", padx=18, pady=(0,4))
        self.url_entry = ctk.CTkEntry(r, height=36, placeholder_text="https://www.youtube.com/watch?v=…  or  https://youtube.com/shorts/…")
        self.url_entry.pack(side="left", fill="x", expand=True, padx=(0,8))
        self.fetch_btn = ctk.CTkButton(r, text="Load Info", width=90,
                                       fg_color=YT_RED, hover_color=YT_HOVER,
                                       command=self._fetch)
        self.fetch_btn.pack(side="left")

        self.info_lbl = ctk.CTkLabel(self, text="", text_color="#4fc3f7", wraplength=620, anchor="w")
        self.info_lbl.pack(fill="x", padx=18)

        # Format
        fr = ctk.CTkFrame(self, fg_color="transparent"); fr.pack(fill="x", **P)
        ctk.CTkLabel(fr, text="Format:").pack(side="left")
        self.fmt_var = ctk.StringVar(value="MP4")
        for f in ("MP4","MP3"):
            ctk.CTkRadioButton(fr, text=f, variable=self.fmt_var,
                               value=f, command=self._fmt_changed,
                               fg_color=YT_RED, hover_color=YT_HOVER).pack(side="left", padx=10)

        # MP4 options
        self.mp4_row = ctk.CTkFrame(self, fg_color="transparent")
        self.mp4_row.pack(fill="x", padx=18, pady=2)
        ctk.CTkLabel(self.mp4_row, text="Resolution:").pack(side="left")
        self.quality_var = ctk.StringVar(value="Best available")
        ctk.CTkOptionMenu(self.mp4_row, variable=self.quality_var,
                          width=160, values=self.QUALITIES,
                          fg_color=YT_RED, button_color=YT_HOVER,
                          button_hover_color="#aa0000").pack(side="left", padx=8)
        ctk.CTkLabel(self.mp4_row, text="FPS:").pack(side="left", padx=(16,0))
        self.fps_var = ctk.StringVar(value="Any FPS")
        ctk.CTkOptionMenu(self.mp4_row, variable=self.fps_var,
                          width=110, values=self.FPS_OPTS,
                          fg_color=YT_RED, button_color=YT_HOVER,
                          button_hover_color="#aa0000").pack(side="left", padx=8)

        # MP3 options (hidden by default)
        self.mp3_row = ctk.CTkFrame(self, fg_color="transparent")
        ctk.CTkLabel(self.mp3_row, text="Bitrate:").pack(side="left")
        self.bitrate_var = ctk.StringVar(value="320k")
        ctk.CTkOptionMenu(self.mp3_row, variable=self.bitrate_var,
                          width=110, values=self.BITRATES,
                          fg_color=YT_RED, button_color=YT_HOVER,
                          button_hover_color="#aa0000").pack(side="left", padx=8)

        # Trim section
        tf = ctk.CTkFrame(self, corner_radius=8); tf.pack(fill="x", padx=18, pady=(8,4))
        self.trim_frame = tf
        th = ctk.CTkFrame(tf, fg_color="transparent"); th.pack(fill="x", padx=12, pady=(8,4))
        self.trim_var = ctk.BooleanVar(value=False)
        ctk.CTkCheckBox(th, text="Trim clip before downloading",
                        variable=self.trim_var, command=self._trim_toggle,
                        fg_color=YT_RED, hover_color=YT_HOVER,
                        checkmark_color="white").pack(side="left")
        self.trim_dur_lbl = ctk.CTkLabel(th, text="", text_color="gray60")
        self.trim_dur_lbl.pack(side="right", padx=8)

        self.trim_body = ctk.CTkFrame(tf, fg_color="transparent")

        # ── Sliders row ──
        sl_frame = ctk.CTkFrame(self.trim_body, fg_color="transparent")
        sl_frame.pack(fill="x", padx=8, pady=(4,0))

        ctk.CTkLabel(sl_frame, text="Start:", width=40, anchor="w").grid(row=0, column=0, padx=(0,4))
        self.trim_start_slider = ctk.CTkSlider(sl_frame, from_=0, to=100, number_of_steps=1000,
                                                fg_color="gray30", progress_color=YT_RED,
                                                button_color=YT_RED, button_hover_color=YT_HOVER,
                                                command=self._on_start_slider)
        self.trim_start_slider.set(0)
        self.trim_start_slider.grid(row=0, column=1, sticky="ew", padx=(0,8))
        self.trim_start = ctk.CTkEntry(sl_frame, width=90, placeholder_text="00:00:00")
        self.trim_start.grid(row=0, column=2)

        ctk.CTkLabel(sl_frame, text="End:", width=40, anchor="w").grid(row=1, column=0, padx=(0,4), pady=(6,0))
        self.trim_end_slider = ctk.CTkSlider(sl_frame, from_=0, to=100, number_of_steps=1000,
                                              fg_color="gray30", progress_color=YT_RED,
                                              button_color=YT_RED, button_hover_color=YT_HOVER,
                                              command=self._on_end_slider)
        self.trim_end_slider.set(100)
        self.trim_end_slider.grid(row=1, column=1, sticky="ew", padx=(0,8), pady=(6,0))
        self.trim_end = ctk.CTkEntry(sl_frame, width=90, placeholder_text="00:00:00")
        self.trim_end.grid(row=1, column=2, pady=(6,0))
        sl_frame.columnconfigure(1, weight=1)

        # Clip duration label
        tr2 = ctk.CTkFrame(self.trim_body, fg_color="transparent"); tr2.pack(fill="x", padx=8, pady=(4,8))
        self.trim_prev = ctk.CTkLabel(tr2, text="", text_color="#4fc3f7")
        self.trim_prev.pack(side="left")

        self.trim_start.bind("<KeyRelease>", lambda e: self._on_start_entry())
        self.trim_end.bind  ("<KeyRelease>", lambda e: self._on_end_entry())



        # Save folder
        sr = ctk.CTkFrame(self, fg_color="transparent"); sr.pack(fill="x", padx=18, pady=(8,4))
        ctk.CTkLabel(sr, text="Save to:").pack(side="left")
        self.save_var = ctk.StringVar(value=get_pref("save_folder_youtube"))
        ctk.CTkEntry(sr, textvariable=self.save_var, width=340).pack(side="left", padx=6)
        ctk.CTkButton(sr, text="Browse…", width=80,
                      fg_color=YT_RED, hover_color=YT_HOVER,
                      command=lambda: self._browse(self.save_var)).pack(side="left")
        self._yt_hist_btn = ctk.CTkButton(sr, text="▾", width=28, height=28,
                      fg_color="transparent", border_width=1,
                      command=lambda: self._show_folder_history("save_folder_youtube", self.save_var, self._yt_hist_btn))
        self._yt_hist_btn.pack(side="left", padx=(4,0))

        # Filename row
        fn_frame = ctk.CTkFrame(self, fg_color="transparent"); fn_frame.pack(fill="x", padx=18, pady=(0,4))
        self._custom_name_var = ctk.BooleanVar(value=False)
        ctk.CTkCheckBox(fn_frame, text="Custom filename:", variable=self._custom_name_var,
                         fg_color=YT_RED, hover_color=YT_HOVER, checkmark_color="white",
                         command=self._toggle_filename).pack(side="left")
        self._filename_entry = ctk.CTkEntry(fn_frame, width=268,
                                             text_color="gray50",
                                             state="disabled")
        self._filename_entry.pack(side="left", padx=(8,0))
        self._fn_clear_btn = ctk.CTkButton(fn_frame, text="✕", width=28, height=28,
                                            fg_color="#cc2222", hover_color="#aa1a1a",
                                            text_color="white", state="disabled",
                                            command=self._clear_filename)
        self._fn_clear_btn.pack(side="left", padx=(4,0))

        # Download button
        self.dl_btn = ctk.CTkButton(self, text="💾  Download", height=40,
                                    font=ctk.CTkFont(size=14, weight="bold"),
                                    fg_color=YT_RED, hover_color=YT_HOVER,
                                    state="disabled",
                                    command=self._start)
        self.dl_btn.pack(pady=10)

        # Progress + log
        self.progress_bar = ctk.CTkProgressBar(self, width=640, progress_color=YT_RED)
        self.progress_bar.set(0); self.progress_bar.pack()
        self.status_lbl = ctk.CTkLabel(self, text="Ready.", text_color="gray60", wraplength=640)
        self.status_lbl.pack(pady=4)
        self.log_box = ctk.CTkTextbox(self, width=640, state="disabled",
                                      font=ctk.CTkFont(family="Courier", size=10))
        self.log_box.pack(padx=18, pady=(0,10), fill="both", expand=True)

        self._fmt_changed()

    def _toggle_filename(self):
        active = self._custom_name_var.get()
        self._filename_entry.configure(
            state="normal"  if active else "disabled",
            text_color="white" if active else "gray50")
        self._fn_clear_btn.configure(state="normal" if active else "disabled")
        if active:
            self._filename_entry.focus_set()
        else:
            # Unticked — restore the original hint if the entry was left empty
            hint = getattr(self, "_last_filename_hint", "")
            if hint and not self._filename_entry.get().strip():
                self._filename_entry.configure(state="normal")
                self._filename_entry.delete(0, "end")
                self._filename_entry.insert(0, hint)
                self._filename_entry.configure(state="disabled", text_color="gray50")

    def _clear_filename(self):
        self._filename_entry.delete(0, "end")
        self._filename_entry.focus_set()

    def _get_outtmpl(self, save):
        custom = self._filename_entry.get().strip() if self._custom_name_var.get() else ""
        if custom:
            return str(Path(save) / f"{custom}.%(ext)s")
        return str(Path(save) / "%(title).80s.%(ext)s")

    def _fmt_changed(self):
        if self.fmt_var.get()=="MP4":
            self.mp3_row.pack_forget()
            self.mp4_row.pack(fill="x", padx=18, pady=2, before=self.trim_frame)
        else:
            self.mp4_row.pack_forget()
            self.mp3_row.pack(fill="x", padx=18, pady=2, before=self.trim_frame)

    def _trim_toggle(self):
        if self.trim_var.get():
            self.trim_body.pack(fill="x")
        else:
            self.trim_body.pack_forget()

    def _on_start_slider(self, val):
        if not self._duration:
            return
        secs = val / 100 * self._duration
        # Clamp below end
        end_secs = _to_sec(self.trim_end.get()) or self._duration
        secs = min(secs, end_secs - 1)
        self.trim_start.delete(0, "end")
        self.trim_start.insert(0, _fmt_sec(secs))
        self._trim_preview()

    def _on_end_slider(self, val):
        if not self._duration:
            return
        secs = val / 100 * self._duration
        # Clamp above start
        start_secs = _to_sec(self.trim_start.get()) or 0
        secs = max(secs, start_secs + 1)
        self.trim_end.delete(0, "end")
        self.trim_end.insert(0, _fmt_sec(secs))
        self._trim_preview()

    def _on_start_entry(self):
        s = _to_sec(self.trim_start.get())
        if s is not None and self._duration:
            self.trim_start_slider.set(min(s / self._duration * 100, 99))
        self._trim_preview()

    def _on_end_entry(self):
        e = _to_sec(self.trim_end.get())
        if e is not None and self._duration:
            self.trim_end_slider.set(min(e / self._duration * 100, 100))
        self._trim_preview()

    def _trim_preview(self):
        s,e = _to_sec(self.trim_start.get()), _to_sec(self.trim_end.get())
        if s is not None and e is not None and e>s:
            self.trim_prev.configure(text=f"Clip: {_fmt_sec(e-s)}", text_color="#4fc3f7")
        else:
            self.trim_prev.configure(text="")

    def _fetch(self):
        url = self.url_entry.get().strip()
        if not url: return
        # Block X/Twitter links — redirect user to the correct tab
        if any(d in url for d in ("x.com", "twitter.com", "t.co")):
            self.info_lbl.configure(
                text="⚠  X/Twitter links aren't supported here — use the 𝕏 X tab to download videos or GIFs.",
                text_color="#ff6b6b")
            return
        # Normalise short URLs and strip tracking params immediately
        url = url.split("?si=")[0].split("&si=")[0]
        if "youtu.be/" in url:
            vid_id = url.split("youtu.be/")[-1].split("?")[0].split("&")[0]
            url = f"https://www.youtube.com/watch?v={vid_id}"
            self.url_entry.delete(0, "end")
            self.url_entry.insert(0, url)
        self.fetch_btn.configure(state="disabled", text="Loading…")
        self.dl_btn.configure(state="disabled")
        self.info_lbl.configure(text="Fetching video info…", text_color="gray55")
        threading.Thread(target=self._do_fetch, args=(url,), daemon=True).start()

    def _do_fetch(self, url):
        import yt_dlp
        is_playlist = "list=" in url and "youtube.com" in url
        TIMEOUT = 25

        def _extract():
            if is_playlist:
                # For playlists: use extract_flat to get entry count quickly
                # but fall back to counting via playlist_count if entries is empty
                opts = {
                    "quiet":             True,
                    "no_warnings":       True,
                    "skip_download":     True,
                    "noplaylist":        False,
                    "extract_flat":      "in_playlist",
                    "playlistend":       1,        # only fetch first entry metadata
                    "ffmpeg_location":   str(_ffmpeg_path),
                    "socket_timeout":    10,
                    "retries":           1,
                    "extractor_retries": 1,
                }
            else:
                opts = {
                    "quiet":             True,
                    "no_warnings":       True,
                    "skip_download":     True,
                    "noplaylist":        True,
                    "ffmpeg_location":   str(_ffmpeg_path),
                    "socket_timeout":    10,
                    "retries":           1,
                    "extractor_retries": 1,
                }
            with yt_dlp.YoutubeDL(opts) as ydl:
                return ydl.extract_info(url, download=False)

        info  = None
        error = None
        try:
            with ThreadPoolExecutor(max_workers=1) as pool:
                future = pool.submit(_extract)
                try:
                    info = future.result(timeout=TIMEOUT)
                except FutureTimeout:
                    future.cancel()
                    error = f"Timed out after {TIMEOUT}s — check your connection or try again."
                except Exception as exc:
                    lines = [l.strip() for l in str(exc).splitlines() if l.strip()]
                    error = lines[-1][:140] if lines else str(exc)[:140]
        except Exception as exc:
            error = str(exc)[:140]

        def _update():
            self.fetch_btn.configure(state="normal", text="Load Info")
            if error or info is None:
                msg = error or "No info returned — is this a valid YouTube URL?"
                self.info_lbl.configure(text=f"⚠  {msg}", text_color="#ff6b6b")
                self.dl_btn.configure(state="disabled")
                return

            if is_playlist:
                # Playlist-level info — prefer playlist_count (accurate total)
                # over len(entries) which may only reflect fetched entries
                pl_title = (info.get("title") or info.get("playlist_title") or "Unknown Playlist")
                uploader = (info.get("uploader") or info.get("channel") or
                            info.get("playlist_uploader") or "?")
                count    = (info.get("playlist_count") or
                            info.get("n_entries") or
                            len(info.get("entries") or []))
                self._duration = None  # trim doesn't apply to playlists
                count_str = f"{count} video{'s' if count != 1 else ''}" if count else "? videos"
                self.info_lbl.configure(
                    text=f'📋  "{pl_title}"  by {uploader}  |  {count_str}',
                    text_color="#4fc3f7")
                self.trim_dur_lbl.configure(text="")
            else:
                # Single video info
                title    = info.get("title", "?")
                uploader = info.get("uploader", "?")
                dur      = info.get("duration")
                self._duration = float(dur) if dur else None
                self._video_url = url
                dur_s = _fmt_sec(self._duration) if self._duration else "?"
                # Reset sliders to full range
                if self._duration:
                    self.trim_start_slider.configure(to=100)
                    self.trim_end_slider.configure(to=100)
                    self.trim_start_slider.set(0)
                    self.trim_end_slider.set(100)
                self.info_lbl.configure(
                    text=f'🎬  "{title}"  by {uploader}  |  {dur_s}',
                    text_color="#4fc3f7")
                self.after(0, lambda t=title: self._set_filename_hint(t))
                if self._duration:
                    end_str = _fmt_sec(self._duration)
                    self.trim_dur_lbl.configure(text=f"Duration: {dur_s}")
                    self.trim_end.delete(0, "end")
                    self.trim_end.insert(0, end_str)
            self.dl_btn.configure(state="normal")

        self.after(0, _update)

    def _build_fmt_str(self):
        h_map = {"Best available":None,"4K (2160p)":2160,"1440p":1440,
                 "1080p":1080,"720p":720,"480p":480}
        h   = h_map.get(self.quality_var.get())
        fps = self.fps_var.get()

        # FPS filter string (appended to video selector only)
        fps_f = "[fps>=50]" if fps=="60 FPS" else ("[fps<=32][fps>0]" if fps=="30 FPS" else "")

        # Always pick the highest quality audio — ffmpeg will re-encode to AAC on merge
        aud = "bestaudio"

        # Video selector — no [ext=] filter here; YouTube serves best quality
        # as webm/vp9 for HD/4K. ffmpeg will remux everything to mp4 cleanly.
        if h:
            # With FPS preference
            vid_fps = f"bestvideo[height<={h}]{fps_f}" if fps_f else f"bestvideo[height<={h}]"
            # Without FPS preference as fallback
            vid_any = f"bestvideo[height<={h}]"
            fmt = (
                f"{vid_fps}+{aud}/"     # exact height + fps + audio
                f"{vid_any}+{aud}/"     # exact height, any fps + audio
                f"bestvideo+{aud}/"     # any height + audio (last resort merge)
                f"best"                 # single-file absolute fallback
            )
        else:
            vid = f"bestvideo{fps_f}" if fps_f else "bestvideo"
            fmt = (
                f"{vid}+{aud}/"
                f"bestvideo+{aud}/"
                f"best"
            )
        return fmt

    def _start(self):
        url  = self.url_entry.get().strip()
        save = self.save_var.get().strip()
        if not url:  messagebox.showwarning("No URL","Paste a YouTube URL first."); return
        if not save: messagebox.showwarning("No folder","Choose a save folder.");   return
        # Normalise short URLs and strip tracking params
        url = url.split("?si=")[0].split("&si=")[0]
        if "youtu.be/" in url:
            vid_id = url.split("youtu.be/")[-1].split("?")[0].split("&")[0]
            url = f"https://www.youtube.com/watch?v={vid_id}"

        playlist = False
        if "list=" in url and "youtube.com" in url:
            ans = messagebox.askyesnocancel("Playlist detected",
                "Playlist URL detected.\n\nYes → full playlist\nNo → this video only\nCancel → abort")
            if ans is None: return
            playlist = bool(ans)

        ts = te = None
        if self.trim_var.get():
            ts, te = _to_sec(self.trim_start.get()), _to_sec(self.trim_end.get())
            if ts is None or te is None:
                messagebox.showwarning("Bad trim","Enter valid times (HH:MM:SS or MM:SS)."); return
            if te <= ts:
                messagebox.showwarning("Bad trim","End must be after start."); return

        os.makedirs(save, exist_ok=True)
        if not self._confirm_download("YouTube download"): return
        self._maybe_clear_log()
        self.dl_btn.configure(state="disabled", text="Downloading…")
        self._set_progress(0); self._log(f"▶  {url}")
        threading.Thread(target=self._worker, args=(url,save,playlist,ts,te), daemon=True).start()

    def _worker(self, url, save, playlist, ts, te):
        import yt_dlp
        is_mp3 = self.fmt_var.get() == "MP3"

        # Template: playlists get their own subfolder, singles go flat
        if playlist:
            tpl = os.path.join(save, "%(playlist_title)s", "%(playlist_index)s - %(title)s.%(ext)s")
        else:
            tpl = os.path.join(save, "%(title)s.%(ext)s")

        opts = {
            "outtmpl":         tpl,
            "noplaylist":      not playlist,
            "progress_hooks":  [self._progress_hook],
            "quiet":           True,
            "no_warnings":     True,
            # Don't use ignoreerrors for single videos — we want to see failures.
            # For playlists keep it True so one bad video doesn't abort the rest.
            "ignoreerrors":    playlist,
            "ffmpeg_location": str(_ffmpeg_path),
            "retries":         5,
            "fragment_retries":10,
            "socket_timeout":  30,
        }

        if is_mp3:
            opts["format"]         = "bestaudio/best"
            opts["postprocessors"] = [{"key":"FFmpegExtractAudio","preferredcodec":"mp3",
                                        "preferredquality":self.bitrate_var.get().replace("k","")}]
        else:
            fmt_str = self._build_fmt_str()
            self.after(0, self._log, f"   Format: {fmt_str}")
            opts["format"]              = fmt_str
            opts["merge_output_format"] = "mp4"
            # Force ffmpeg to re-encode audio as AAC during the merge step.
            # This guarantees every output file has compatible audio regardless
            # of whether YouTube provided m4a, Opus, or anything else.
            # Video stream is copied as-is (no quality loss), only audio is touched.
            opts["postprocessor_args"] = {
                "ffmpeg": ["-c:v", "copy", "-c:a", "aac", "-b:a", "192k"]
            }

        # Trim: cut the clip. Audio re-encode above still applies.
        if ts is not None:
            opts["postprocessors"] = opts.get("postprocessors", []) + [
                {"key": "FFmpegVideoConvertor", "preferedformat": "mp4"}
            ]
            # Merge trim args with AAC encode args so neither overwrites the other.
            # Order: seek first (-ss/-to), then codec flags (-c:v copy -c:a aac)
            existing = opts.get("postprocessor_args", {}).get("ffmpeg", [])
            trim_args = ["-ss", str(ts), "-to", str(te)]
            # Remove duplicate codec flags if already in existing to avoid conflicts
            codec_flags = ["-c:v", "copy", "-c:a", "aac", "-b:a", "192k"]
            merged = trim_args + [f for f in existing if f not in trim_args]
            if not any(f in merged for f in ["-c:a", "-acodec"]):
                merged += codec_flags
            opts["postprocessor_args"] = {"ffmpeg": merged}

        try:
            with yt_dlp.YoutubeDL(opts) as ydl:
                ydl.download([url])
            self.after(0, self._done, save)
        except Exception as exc:
            self.after(0, self._err, str(exc))

    def _done(self, save):
        push_folder_history("save_folder_youtube", save)
        self.dl_btn.configure(state="normal", text="💾  Download")
        self._set_progress(1.0); self._set_status("✅  Done!")
        self._log(f"Saved to: {save}")
        _notify_done(save, self._open_folder, self._last_file)

    def _err(self, msg):
